# Supabase Configuration (required)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
NEXT_PUBLIC_SUPABASE_READ_URL="your-supabase-read-replica-url" # Optional: defaults to NEXT_PUBLIC_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database Connections
# Use Port 5432 for migrations and direct access
# Use Port 6543 for application runtime (PgBouncer Pooled)
# Append &options=-c%20statement_timeout%3D30000 to cap individual query duration at 30 s
DATABASE_URL="postgres://postgres:password@db.project.supabase.co:6543/postgres?pgbouncer=true&options=-c%20statement_timeout%3D30000"
DIRECT_URL="postgres://postgres:password@db.project.supabase.co:5432/postgres"

# Query timeout in milliseconds — used as the default timeout for Prisma $transaction calls
DB_QUERY_TIMEOUT_MS=30000

# Payment Gateway Configuration (as needed)
BILLING_PROVIDER="SSL_WIRELESS"
BACKEND_PUBLIC_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
PLATFORM_ADMIN_EMAILS="nayeem.ahmad@gmail.com"

SSL_WIRELESS_STORE_ID="your-ssl-wireless-store-id"
SSL_WIRELESS_STORE_PASSWORD="your-ssl-wireless-store-password"
SSL_WIRELESS_API_URL="https://sandbox.sslcommerz.com/gwprocess/v4/api.php"
SSL_WIRELESS_VALIDATION_URL="https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php"
SSL_WIRELESS_SUCCESS_REDIRECT="http://localhost:3000/dashboard/billing"
SSL_WIRELESS_FAIL_REDIRECT="http://localhost:3000/dashboard/billing"
SSL_WIRELESS_CANCEL_REDIRECT="http://localhost:3000/dashboard/billing"

BKASH_APP_KEY="your-bkash-app-key"
BKASH_APP_SECRET="your-bkash-app-secret"
BKASH_API_URL="https://api.bkash.com/sandbox"

NAGAD_MERCHANT_ID="your-nagad-merchant-id"
NAGAD_API_KEY="your-nagad-api-key"
NAGAD_API_URL="https://api.nagad.com.bd/sandbox"

# Upstash Redis Configuration (for Rate Limiting)
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"
