# Supabase Configuration (required)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
NEXT_PUBLIC_SUPABASE_READ_URL="your-supabase-read-replica-url" # Optional: defaults to NEXT_PUBLIC_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database Connections
# Use Port 5432 for migrations and direct access
# Use Port 6543 for application runtime (PgBouncer Pooled)
DATABASE_URL="postgres://postgres:password@db.project.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres:password@db.project.supabase.co:5432/postgres"

# Payment Gateway Configuration (as needed)
BILLING_PROVIDER="SSL_WIRELESS"
BACKEND_PUBLIC_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
PLATFORM_ADMIN_EMAILS="nayeem.ahmad@gmail.com"

SSL_WIRELESS_STORE_ID="your-ssl-wireless-store-id"
SSL_WIRELESS_STORE_PASSWORD="your-ssl-wireless-store-password"
SSL_WIRELESS_API_URL="https://sandbox.sslcommerz.com/gwprocess/v4/api.php"
SSL_WIRELESS_VALIDATION_URL="https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php"
SSL_WIRELESS_SUCCESS_REDIRECT="http://localhost:3000/dashboard/billing"
SSL_WIRELESS_FAIL_REDIRECT="http://localhost:3000/dashboard/billing"
SSL_WIRELESS_CANCEL_REDIRECT="http://localhost:3000/dashboard/billing"

BKASH_APP_KEY="your-bkash-app-key"
BKASH_APP_SECRET="your-bkash-app-secret"
BKASH_API_URL="https://api.bkash.com/sandbox"

NAGAD_MERCHANT_ID="your-nagad-merchant-id"
NAGAD_API_KEY="your-nagad-api-key"
NAGAD_API_URL="https://api.nagad.com.bd/sandbox"

# Upstash Redis Configuration (for Rate Limiting)
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"

# System Health Monitoring (platform-admin, GET /api/v1/admin/system-health)
HEALTH_DEP_TIMEOUT_MS="2000"            # Per-provider reachability probe timeout
HEALTH_DB_LATENCY_DEGRADED_MS="1000"   # DB query latency above this = degraded
HEALTH_DB_POOL_DEGRADED_PCT="80"       # Connection-pool % above this = degraded
# Prometheus metrics scrape endpoint (GET /api/v1/metrics). Leave unset to disable.
METRICS_TOKEN=""                        # Bearer token a scraper must present
# Threshold alerting — notify platform admins when the system is degraded/down
HEALTH_ALERT_EMAILS=""                   # Comma-separated alert recipients
HEALTH_ALERT_SMS=""                      # Optional comma-separated phone numbers
HEALTH_ALERT_COOLDOWN_MIN="30"           # Min minutes between repeat alerts
HEALTH_PAYMENT_FAILURE_THRESHOLD="3"     # FAILED billing events in window = degraded
HEALTH_PAYMENT_FAILURE_WINDOW_MIN="60"   # Look-back window for payment failures
SMS_CREDIT_LOW_THRESHOLD="100"           # A tenant at/below this credit count is low
SMS_CREDIT_LOW_TENANTS_ALERT="5"         # Low-credit tenant count that = degraded

# Email (Brevo SMTP - https://brevo.com)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="your-brevo-smtp-login"
SMTP_PASS="your-brevo-smtp-key"
EMAIL_FROM="noreply@yourdomain.com"
SUPPORT_EMAIL="support@yourdomain.com"
FEEDBACK_EMAIL="feedback@yourdomain.com"

# Cloudinary (file storage - https://cloudinary.com)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# SMS (BulkSMSBD - https://bulksmsbd.net)
SMS_API_KEY="your-bulksmsbd-api-key"
SMS_SENDER_ID="8809617621294"

# Sentry Error Tracking (https://sentry.io)
SENTRY_DSN="https://your-key@sentry.io/your-project-id"
NEXT_PUBLIC_SENTRY_DSN="https://your-key@sentry.io/your-project-id"
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="retail-saas-frontend"

# Field-level encryption key — 32 bytes as 64-char hex or base64 (Render generateValue uses base64)
# Generate hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY="your-64-hex-char-encryption-key"

# OpenRouter AI (https://openrouter.ai/keys)
# Required for AI-powered features (report narration, message drafting)
OPENROUTER_API_KEY="sk-or-your-key-here"
# Optional: override default model slug (see https://openrouter.ai/models)
# OPENROUTER_DEFAULT_MODEL="anthropic/claude-haiku-4.5"
# Optional: app name shown on OpenRouter rankings
# OPENROUTER_APP_NAME="RetailSaaS"
