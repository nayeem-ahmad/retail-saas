NODE_ENV=production

# Public application URLs — erp71.com
FRONTEND_URL=https://app.erp71.com
BACKEND_PUBLIC_URL=https://api.erp71.com
NEXT_PUBLIC_API_BASE=https://api.erp71.com
NEXT_PUBLIC_API_URL=https://api.erp71.com

# Shared VPS Postgres (retail-saas-db-1 on the retail-saas_default network)
ERP71_DB_NAME=erp71_retail_saas
ERP71_DB_USER=erp71_app
ERP71_DB_PASSWORD=change-this-erp71-db-password
DATABASE_URL=postgresql://erp71_app:change-this-erp71-db-password@retail-saas-db-1:5432/erp71_retail_saas
DIRECT_URL=postgresql://erp71_app:change-this-erp71-db-password@retail-saas-db-1:5432/erp71_retail_saas

# Auth — use unique secrets per instance (do not copy from nayeemahmad.com)
JWT_SECRET=generate-a-long-random-secret
FIELD_ENCRYPTION_KEY=generate-64-hex-chars
PLATFORM_ADMIN_EMAILS=you@example.com
REQUIRE_EMAIL_VERIFICATION=true

# Copy remaining keys from the primary .env.production (Supabase, SMTP, billing, etc.)
# and update any *REDIRECT* URLs to https://app.erp71.com/...