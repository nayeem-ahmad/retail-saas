{
  "name": "erp71",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prepare": "bash scripts/setup-git-hooks.sh"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "prisma": "^5.22.0"
  }
}
