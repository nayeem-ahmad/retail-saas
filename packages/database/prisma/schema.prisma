  @@index([tenant_id, warehouse_id, status])
  @@index([tenant_id, created_at])
}

model StockTakeCountLine {
  id                String   @id @default(uuid())
  session_id        String
  product_id        String
  expected_quantity Int
  counted_quantity  Int?
  variance_quantity Int?
  reason_id         String?
