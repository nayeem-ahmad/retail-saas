  session           StockTakeSession  @relation(fields: [session_id], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [product_id], references: [id])
  reason            InventoryReason?  @relation(fields: [reason_id], references: [id])

  @@unique([session_id, product_id])
  @@index([session_id, variance_quantity])
}

model Supplier {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  phone       String?
  email       String?
  address     String?
  due_balance Decimal  @default(0) @db.Decimal(12, 2)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  purchases   Purchase[]
  purchaseReturns PurchaseReturn[]
  purchaseOrders PurchaseOrder[]
  purchaseQuotations PurchaseQuotation[]
  creditTransactions SupplierCreditTransaction[]

  @@unique([tenant_id, name])
}

model SupplierCreditTransaction {
  id             String   @id @default(uuid())
  tenant_id      String
  supplier_id    String
  type           String   // CREDIT_PURCHASE | PAYMENT | PAYOUT | ADJUSTMENT
  amount         Decimal  @db.Decimal(12, 2)
  balance_after  Decimal  @db.Decimal(12, 2)
  reference_type String?
  reference_id   String?
  payment_number String?
  notes          String?
  created_by     String?
  created_at     DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  supplier  Supplier  @relation(fields: [supplier_id], references: [id], onDelete: Cascade)
  creator   User?     @relation("SupplierCreditTransactionCreator", fields: [created_by], references: [id])

  @@unique([tenant_id, payment_number])
  @@index([tenant_id, supplier_id])
  @@index([tenant_id, created_at])
}

model Purchase {
  id              String   @id @default(uuid())
  tenant_id       String
  store_id        String
  supplier_id     String?
  purchase_number String
  subtotal_amount Decimal  @default(0) @db.Decimal(12, 2)
  tax_amount      Decimal  @default(0) @db.Decimal(12, 2)
  discount_amount Decimal  @default(0) @db.Decimal(12, 2)
  freight_amount  Decimal  @default(0) @db.Decimal(12, 2)
  total_amount    Decimal  @default(0) @db.Decimal(12, 2)
  notes           String?
  created_by      String?
  created_at      DateTime @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store           Store     @relation(fields: [store_id], references: [id])
  supplier        Supplier? @relation(fields: [supplier_id], references: [id])
  items           PurchaseItem[]
  returns         PurchaseReturn[]

  @@unique([tenant_id, purchase_number])
  @@index([tenant_id, created_at])
  @@index([tenant_id, store_id])
}

model PurchaseItem {
  id            String   @id @default(uuid())
  purchase_id   String
  product_id    String
  quantity      Int
  unit_cost     Decimal  @db.Decimal(12, 2)
  line_total    Decimal  @db.Decimal(12, 2)

  purchase      Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [product_id], references: [id])
  returnItems   PurchaseReturnItem[]
}

model PurchaseReturn {
  id               String   @id @default(uuid())
  tenant_id        String
  store_id         String
  purchase_id      String
  supplier_id      String?
  return_number    String
  reference_number String?
  total_amount     Decimal  @default(0) @db.Decimal(12, 2)
  notes            String?
  status           String   @default("RECORDED")
  created_by       String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store            Store     @relation(fields: [store_id], references: [id])
  purchase         Purchase  @relation(fields: [purchase_id], references: [id])
  supplier         Supplier? @relation(fields: [supplier_id], references: [id])
  items            PurchaseReturnItem[]

  @@unique([tenant_id, return_number])
}

model PurchaseReturnItem {
  id               String   @id @default(uuid())
  return_id        String
  purchase_item_id String
  product_id       String
  quantity         Int
  unit_cost        Decimal  @db.Decimal(12, 2)
  line_total       Decimal  @db.Decimal(12, 2)

  purchaseReturn   PurchaseReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)
  purchaseItem     PurchaseItem   @relation(fields: [purchase_item_id], references: [id])
  product          Product        @relation(fields: [product_id], references: [id])
}

model PurchaseOrder {
  id              String    @id @default(uuid())
  tenant_id       String
  store_id        String
  supplier_id     String?
  po_number       String
  status          String    @default("DRAFT")
  expected_date   DateTime?
  subtotal_amount Decimal   @default(0) @db.Decimal(12, 2)
  tax_amount      Decimal   @default(0) @db.Decimal(12, 2)
  discount_amount Decimal   @default(0) @db.Decimal(12, 2)
  freight_amount  Decimal   @default(0) @db.Decimal(12, 2)
  total_amount    Decimal   @default(0) @db.Decimal(12, 2)
  notes           String?
  received_at     DateTime?
  created_by      String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store    Store     @relation(fields: [store_id], references: [id])
  supplier Supplier? @relation(fields: [supplier_id], references: [id])
  items    PurchaseOrderItem[]

  @@unique([tenant_id, po_number])
  @@index([tenant_id, created_at])
  @@index([tenant_id, status])
}

model PurchaseOrderItem {
  id         String  @id @default(uuid())
  po_id      String
  product_id String
  quantity   Int
  unit_cost  Decimal @db.Decimal(12, 2)
  line_total Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [po_id], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [product_id], references: [id])
}

model PurchaseQuotation {
  id              String    @id @default(uuid())
  tenant_id       String
  store_id        String
  supplier_id     String?
  rfq_number      String
  status          String    @default("DRAFT")
  valid_until     DateTime?
  total_amount    Decimal   @default(0) @db.Decimal(12, 2)
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store    Store     @relation(fields: [store_id], references: [id])
  supplier Supplier? @relation(fields: [supplier_id], references: [id])
  items    PurchaseQuotationItem[]

  @@unique([tenant_id, rfq_number])
  @@index([tenant_id, created_at])
  @@index([tenant_id, status])
}

model PurchaseQuotationItem {
  id         String  @id @default(uuid())
  rfq_id     String
  product_id String
  quantity   Int
  unit_cost  Decimal @db.Decimal(12, 2)
  line_total Decimal @db.Decimal(12, 2)

  purchaseQuotation PurchaseQuotation @relation(fields: [rfq_id], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [product_id], references: [id])
}

model Sale {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  counter_id     String?
  serial_number  String
  reference_number String?  // User-editable reference, unique per tenant
  total_amount   Decimal  @db.Decimal(12, 2)
  amount_paid    Decimal    @default(0) @db.Decimal(12, 2)
  status         String
  note           String?
  created_by     String?
  created_at     DateTime @default(now())

  // Relations
  tenant         Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store       @relation(fields: [store_id], references: [id])
  counter        PosCounter? @relation(fields: [counter_id], references: [id])
  customer_id    String?
  customer       Customer? @relation(fields: [customer_id], references: [id])
  items          SaleItem[]
  payments       PaymentRecord[]
  returns        SalesReturn[]
  warrantyClaims WarrantyClaim[]
  deliveryOrders DeliveryOrder[]

  @@unique([tenant_id, serial_number])
  @@unique([tenant_id, reference_number])
  @@index([tenant_id, created_at])
  @@index([tenant_id, store_id])
  @@index([tenant_id, customer_id])
  @@index([tenant_id, counter_id])
}

model Customer {
  id                   String        @id @default(uuid())
  tenant_id            String
  customer_code        String
  name                 String
  phone                String
  email                String?
  address              String?
  profile_pic_url      String?
  customer_type        CustomerType  @default(INDIVIDUAL)
  customer_group_id    String?
  territory_id         String?
  credit_limit         Decimal?      @db.Decimal(12, 2)
  default_discount_pct Decimal?      @db.Decimal(5, 2)
  total_spent          Decimal       @default(0) @db.Decimal(12, 2)
  nid                  String?
  segment_category     String        @default("Regular")
  loyalty_points       Int           @default(0)
  due_balance          Decimal       @default(0) @db.Decimal(12, 2)
  credit_enabled       Boolean       @default(false)
  last_contacted_at    DateTime?
  preferred_channel    String        @default("PHONE")
  birthday             DateTime?
  anniversary          DateTime?
  created_at           DateTime      @default(now())
  deleted_at           DateTime?
  user_id              String?       @unique

  // Relations
  tenant           Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customerGroup    CustomerGroup? @relation(fields: [customer_group_id], references: [id])
  territory        Territory?     @relation(fields: [territory_id], references: [id])
  user             User?          @relation(fields: [user_id], references: [id])
  sales            Sale[]
  salesOrders      SalesOrder[]
  quotations       Quotation[]
  warrantyClaims   WarrantyClaim[]
  loyaltyTransactions LoyaltyTransaction[]
  interactions       CustomerInteraction[]
  crmTasks           CrmTask[]
  creditTransactions CustomerCreditTransaction[]
  campaignRecipients CrmCampaignRecipient[]
  convertedFromLeads Lead[] @relation("LeadConvertedCustomer")

  @@unique([tenant_id, phone])
  @@unique([tenant_id, customer_code])
  @@index([tenant_id, deleted_at])
  @@index([tenant_id, email])
}

model CustomerGroup {
  id                   String   @id @default(uuid())
  tenant_id            String
  name                 String
  description          String?
  default_discount_pct Decimal? @db.Decimal(5, 2)
  price_list_id        String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  // Relations
  tenant    Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  priceList PriceList? @relation(fields: [price_list_id], references: [id], onDelete: SetNull)
  customers Customer[]

  @@unique([tenant_id, name])
  @@index([price_list_id])
}

model PriceList {
  id                     String                 @id @default(uuid())
  tenant_id              String
  name                   String
  description            String?
  is_default             Boolean                @default(false)
  is_active              Boolean                @default(true)
  overall_discount_type  PriceListDiscountType?
  overall_discount_value Decimal?               @db.Decimal(12, 2)
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt

  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  items          PriceListItem[]
  customerGroups CustomerGroup[]

  @@unique([tenant_id, name])
  @@index([tenant_id, is_default])
}

model PriceListItem {
  id             String                 @id @default(uuid())
  price_list_id  String
  product_id     String
  selling_price  Decimal?               @db.Decimal(12, 2)
  discount_type  PriceListDiscountType?
  discount_value Decimal?               @db.Decimal(12, 2)
  created_at     DateTime               @default(now())
  updated_at     DateTime               @updatedAt

  priceList PriceList @relation(fields: [price_list_id], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([price_list_id, product_id])
  @@index([price_list_id])
}

model Territory {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  parent_id   String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  tenant    Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent    Territory?  @relation("TerritoryHierarchy", fields: [parent_id], references: [id])
  children  Territory[] @relation("TerritoryHierarchy")
  customers Customer[]

  @@unique([tenant_id, name, parent_id])
}

model CustomerInteraction {
  id          String   @id @default(uuid())
  tenant_id   String
  store_id    String?
  customer_id String
  type        String   // CALL | SMS | WHATSAPP | EMAIL | VISIT | NOTE
  direction   String   @default("OUTBOUND")
  summary     String
  outcome     String?
  created_by  String?
  created_at  DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  creator   User?     @relation("InteractionCreator", fields: [created_by], references: [id])

  @@index([tenant_id, customer_id])
  @@index([tenant_id, created_at])
}

model Lead {
  id                      String    @id @default(uuid())
  tenant_id               String
  store_id                String?
  name                    String
  mobile                  String
  email                   String?
  address                 String?
  category                String?
  priority                String    @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  remarks                 String?
  source                  String    @default("OTHER") // WALK_IN | PHONE | FACEBOOK | REFERRAL | WEBSITE | OTHER
  status                  String    @default("NEW")     // NEW | CONTACTED | QUALIFIED | LOST | CONVERTED
  linkedin_url            String?
  fb_url                  String?
  x_url                   String?
  website_url             String?
  next_step               String?
  next_step_date          DateTime?
  next_step_assigned_to   String?
  assigned_to             String?
  last_contacted_at       DateTime?
  converted_customer_id   String?
  created_by              String?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  tenant               Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  assignee             User?     @relation("LeadAssignee", fields: [assigned_to], references: [id])
  nextStepAssignee     User?     @relation("LeadNextStepAssignee", fields: [next_step_assigned_to], references: [id])
  creator              User?     @relation("LeadCreator", fields: [created_by], references: [id])
  convertedCustomer    Customer? @relation("LeadConvertedCustomer", fields: [converted_customer_id], references: [id])
  conversations        LeadConversation[]
  crmTasks             CrmTask[]

  @@unique([tenant_id, mobile])
  @@index([tenant_id, status])
  @@index([tenant_id, category])
  @@index([tenant_id, priority])
  @@index([tenant_id, assigned_to])
  @@index([tenant_id, next_step_date])
}

model LeadConversation {
  id          String   @id @default(uuid())
  tenant_id   String
  store_id    String?
  lead_id     String
  type        String   // CALL | SMS | WHATSAPP | EMAIL | VISIT | NOTE
  direction   String   @default("OUTBOUND")
  summary     String
  outcome     String?
  created_by  String?
  created_at  DateTime @default(now())

  tenant   Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  lead     Lead   @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  creator  User?  @relation("LeadConversationCreator", fields: [created_by], references: [id])

  @@index([tenant_id, lead_id])
  @@index([tenant_id, created_at])
}

model CrmTask {
  id           String    @id @default(uuid())
  tenant_id    String
  store_id     String?
  customer_id  String?
  lead_id      String?
  type         String    // FOLLOW_UP | COLLECTION | BIRTHDAY | REORDER_REMINDER
  title        String
  due_at       DateTime
  completed_at DateTime?
  assigned_to  String?
  created_by   String?
  notes        String?
  status       String    @default("PENDING")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  tenant   Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  assignee User?     @relation("CrmTaskAssignee", fields: [assigned_to], references: [id])
  creator  User?     @relation("CrmTaskCreator", fields: [created_by], references: [id])

  @@index([tenant_id, status, due_at])
  @@index([tenant_id, customer_id])
  @@index([tenant_id, lead_id])
}

model CustomerCreditTransaction {
  id             String   @id @default(uuid())
  tenant_id      String
  customer_id    String
