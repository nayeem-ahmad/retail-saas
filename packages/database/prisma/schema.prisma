datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  ACCOUNTANT
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum CustomerType {
  INDIVIDUAL
  ORGANIZATION
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String
  name          String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
   
  // Relations
  tenantsOwned  Tenant[]     @relation("TenantOwner")
  tenantMembers TenantUser[]
  cashierSessions CashierSession[]
}

model Tenant {
  id         String   @id @default(uuid())
  name       String
  owner_id   String
  created_at DateTime @default(now())
   
  // Relations
  owner      User     @relation("TenantOwner", fields: [owner_id], references: [id])
  stores     Store[]
  users      TenantUser[]
  subscription TenantSubscription?
   
  products   Product[]
  productStocks ProductStock[]
  sales      Sale[]
  salesReturns SalesReturn[]
  purchaseReturns PurchaseReturn[]
  salesOrders SalesOrder[]
  quotations Quotation[]
  suppliers  Supplier[]
  purchases  Purchase[]
  customers  Customer[]
  customerGroups CustomerGroup[]
  territories    Territory[]
  accountGroups  AccountGroup[]
  accountSubgroups AccountSubgroup[]
  accounts Account[]
  voucherSequences VoucherSequence[]
  vouchers Voucher[]
  cashierSessions CashierSession[]
  cashTransactions CashTransaction[]
}

model TenantUser {
  id        String   @id @default(uuid())
  tenant_id String
  user_id   String
  role      UserRole @default(CASHIER)
  
  // Relations
  tenant    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id])
}

model Store {
  id        String   @id @default(uuid())
  tenant_id String
  name      String
  address   String?
  created_at DateTime @default(now())
   
  // Relations
  tenant    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sales     Sale[]
  salesReturns SalesReturn[]
  purchaseReturns PurchaseReturn[]
  salesOrders SalesOrder[]
  quotations Quotation[]
  purchases Purchase[]
  cashierSessions CashierSession[]
}

model Product {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  sku         String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  image_url   String?
  created_at  DateTime @default(now())
  
  // Relations
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  stocks      ProductStock[]
  saleItems   SaleItem[]
  returnItems SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  orderItems  SalesOrderItem[]
  quoteItems  QuotationItem[]
  purchaseItems PurchaseItem[]

  @@unique([tenant_id, sku])
}

model ProductStock {
  id          String   @id @default(uuid())
  tenant_id   String
  product_id  String
  quantity    Int      @default(0)
  
  // Relations
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id]) // Simplification for v0.1 (one stock record per product)
}

model Supplier {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  phone       String?
  email       String?
  address     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  purchases   Purchase[]
  purchaseReturns PurchaseReturn[]

  @@unique([tenant_id, name])
}

model Purchase {
  id              String   @id @default(uuid())
  tenant_id       String
  store_id        String
  supplier_id     String?
  purchase_number String
  subtotal_amount Decimal  @default(0) @db.Decimal(12, 2)
  tax_amount      Decimal  @default(0) @db.Decimal(12, 2)
  discount_amount Decimal  @default(0) @db.Decimal(12, 2)
  freight_amount  Decimal  @default(0) @db.Decimal(12, 2)
  total_amount    Decimal  @default(0) @db.Decimal(12, 2)
  notes           String?
  created_at      DateTime @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store           Store     @relation(fields: [store_id], references: [id])
  supplier        Supplier? @relation(fields: [supplier_id], references: [id])
  items           PurchaseItem[]
  returns         PurchaseReturn[]

  @@unique([tenant_id, purchase_number])
}

model PurchaseItem {
  id            String   @id @default(uuid())
  purchase_id   String
  product_id    String
  quantity      Int
  unit_cost     Decimal  @db.Decimal(12, 2)
  line_total    Decimal  @db.Decimal(12, 2)

  purchase      Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [product_id], references: [id])
  returnItems   PurchaseReturnItem[]
}

model PurchaseReturn {
  id               String   @id @default(uuid())
  tenant_id        String
  store_id         String
  purchase_id      String
  supplier_id      String?
  return_number    String
  reference_number String?
  total_amount     Decimal  @default(0) @db.Decimal(12, 2)
  notes            String?
  status           String   @default("RECORDED")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store            Store     @relation(fields: [store_id], references: [id])
  purchase         Purchase  @relation(fields: [purchase_id], references: [id])
  supplier         Supplier? @relation(fields: [supplier_id], references: [id])
  items            PurchaseReturnItem[]

  @@unique([tenant_id, return_number])
}

model PurchaseReturnItem {
  id               String   @id @default(uuid())
  return_id        String
  purchase_item_id String
  product_id       String
  quantity         Int
  unit_cost        Decimal  @db.Decimal(12, 2)
  line_total       Decimal  @db.Decimal(12, 2)

  purchaseReturn   PurchaseReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)
  purchaseItem     PurchaseItem   @relation(fields: [purchase_item_id], references: [id])
  product          Product        @relation(fields: [product_id], references: [id])
}

model Sale {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  serial_number  String
  total_amount   Decimal  @db.Decimal(12, 2)
  amount_paid    Decimal    @default(0) @db.Decimal(12, 2)
  status         String
  note           String?
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  customer_id    String?
  customer       Customer? @relation(fields: [customer_id], references: [id])
  items          SaleItem[]
  payments       PaymentRecord[]
  returns        SalesReturn[]
  
  @@unique([tenant_id, serial_number])
}

model Customer {
  id                   String        @id @default(uuid())
  tenant_id            String
  customer_code        String
  name                 String
  phone                String
  email                String?
  address              String?
  profile_pic_url      String?
  customer_type        CustomerType  @default(INDIVIDUAL)
  customer_group_id    String?
  territory_id         String?
  credit_limit         Decimal?      @db.Decimal(12, 2)
  default_discount_pct Decimal?      @db.Decimal(5, 2)
  total_spent          Decimal       @default(0) @db.Decimal(12, 2)
  segment_category     String        @default("Regular")
  created_at           DateTime      @default(now())

  // Relations
  tenant           Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customerGroup    CustomerGroup? @relation(fields: [customer_group_id], references: [id])
  territory        Territory?     @relation(fields: [territory_id], references: [id])
  sales            Sale[]
  salesOrders      SalesOrder[]
  quotations       Quotation[]

  @@unique([tenant_id, phone])
  @@unique([tenant_id, customer_code])
}

model CustomerGroup {
  id                   String   @id @default(uuid())
  tenant_id            String
  name                 String
  description          String?
  default_discount_pct Decimal? @db.Decimal(5, 2)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  // Relations
  tenant    Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customers Customer[]

  @@unique([tenant_id, name])
}

model Territory {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  parent_id   String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  tenant    Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent    Territory?  @relation("TerritoryHierarchy", fields: [parent_id], references: [id])
  children  Territory[] @relation("TerritoryHierarchy")
  customers Customer[]

  @@unique([tenant_id, name, parent_id])
}

model AccountGroup {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  type       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  subgroups  AccountSubgroup[]
  accounts   Account[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@map("account_groups")
}

model AccountSubgroup {
  id         String   @id @default(uuid())
  tenant_id  String
  group_id   String
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  group      AccountGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  accounts   Account[]

  @@unique([group_id, name])
  @@index([tenant_id])
  @@index([group_id])
  @@map("account_subgroups")
}

model Account {
  id          String   @id @default(uuid())
  tenant_id   String
  group_id    String
  subgroup_id String?
  name        String
  code        String?
  type        String
  category    String   @default("general")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  group       AccountGroup    @relation(fields: [group_id], references: [id])
  subgroup    AccountSubgroup? @relation(fields: [subgroup_id], references: [id])
  voucherDetails VoucherDetail[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@index([group_id])
  @@index([subgroup_id])
  @@index([tenant_id, type])
  @@index([tenant_id, category])
  @@map("accounts")
}

model VoucherSequence {
  id           String   @id
  tenant_id    String
  voucher_type String
  prefix       String
  next_number  Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, voucher_type])
  @@index([tenant_id])
  @@map("voucher_sequences")
}

model Voucher {
  id               String   @id @default(uuid())
  tenant_id        String
  voucher_number   String
  voucher_type     String
  description      String?
  reference_number String?
  date             DateTime @default(now())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  details          VoucherDetail[]

  @@unique([tenant_id, voucher_number])
  @@index([tenant_id])
  @@index([tenant_id, voucher_type])
  @@index([date])
  @@map("vouchers")
}

model VoucherDetail {
  id            String   @id @default(uuid())
  voucher_id    String
  account_id    String
  debit_amount  Decimal  @default(0) @db.Decimal(12, 2)
  credit_amount Decimal  @default(0) @db.Decimal(12, 2)
  comment       String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  voucher       Voucher  @relation(fields: [voucher_id], references: [id], onDelete: Cascade)
  account       Account  @relation(fields: [account_id], references: [id])

  @@index([voucher_id])
  @@index([account_id])
  @@map("voucher_details")
}

model PaymentRecord {
  id             String   @id @default(uuid())
  sale_id        String
  payment_method String
  amount         Decimal  @db.Decimal(12, 2)
  created_at     DateTime @default(now())
  
  // Relations
  sale           Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
}

model SaleItem {
  id            String   @id @default(uuid())
  sale_id       String
  product_id    String
  quantity      Int
  price_at_sale Decimal  @db.Decimal(12, 2)
  
  // Relations
  sale          Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [product_id], references: [id])
  returns       SalesReturnItem[]
}

model SalesReturn {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  sale_id        String
  return_number  String
  total_refund   Decimal  @db.Decimal(12, 2)
  reason         String?
  status         String   @default("COMPLETED")
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  sale           Sale     @relation(fields: [sale_id], references: [id])
  items          SalesReturnItem[]

  @@unique([tenant_id, return_number])
}

model SalesReturnItem {
  id             String   @id @default(uuid())
  return_id      String
  sale_item_id   String
  product_id     String
  quantity       Int
  refund_amount  Decimal  @db.Decimal(12, 2)
  
  // Relations
  return         SalesReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)
  sale_item      SaleItem    @relation(fields: [sale_item_id], references: [id])
  product        Product     @relation(fields: [product_id], references: [id])
}

model SalesOrder {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  customer_id    String?
  order_number   String
  total_amount   Decimal  @db.Decimal(12, 2)
  amount_paid    Decimal    @default(0) @db.Decimal(12, 2)
  status         String   @default("DRAFT") // DRAFT, CONFIRMED, PROCESSING, DELIVERED, CANCELLED
  payment_status String   @default("UNPAID") // UNPAID, PARTIAL, PAID
  delivery_date  DateTime?
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  customer       Customer? @relation(fields: [customer_id], references: [id])
  items          SalesOrderItem[]
  deposits       OrderDeposit[]

  @@unique([tenant_id, order_number])
}

model SalesOrderItem {
  id             String   @id @default(uuid())
  order_id       String
  product_id     String
  quantity       Int
  price_at_order Decimal  @db.Decimal(12, 2)
  
  // Relations
  order          SalesOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product        Product    @relation(fields: [product_id], references: [id])
}

model OrderDeposit {
  id             String   @id @default(uuid())
  order_id       String
  amount         Decimal  @db.Decimal(12, 2)
  payment_method String
  created_at     DateTime @default(now())
  
  // Relations
  order          SalesOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model Quotation {
  id                String   @id @default(uuid())
  tenant_id         String
  store_id          String
  customer_id       String?
  quote_number      String
  total_amount      Decimal  @db.Decimal(12, 2)
  status            String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED, REVISED
  valid_until       DateTime?
  version           Int      @default(1)
  original_quote_id String?
  notes             String?
  created_at        DateTime @default(now())
  
  // Relations
  tenant            Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store             Store    @relation(fields: [store_id], references: [id])
  customer          Customer? @relation(fields: [customer_id], references: [id])
  items             QuotationItem[]

  @@unique([tenant_id, quote_number, version])
}

model QuotationItem {
  id             String   @id @default(uuid())
  quotation_id   String
  product_id     String
  quantity       Int
  unit_price     Decimal  @db.Decimal(12, 2)
  
  // Relations
  quotation      Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [product_id], references: [id])
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String
  monthly_price Decimal  @db.Decimal(12, 2)
  features_json Json     @default("{}")
  is_active     Boolean  @default(true)
  subscriptions TenantSubscription[]
}

model CashierSession {
  id            String   @id @default(uuid())
  tenant_id     String
  store_id      String
  user_id       String   // The cashier/user who opened the session
  opened_at     DateTime @default(now())
  closed_at     DateTime?
  opening_cash  Decimal  @default(0) @db.Decimal(12, 2)
  closing_cash  Decimal  @default(0) @db.Decimal(12, 2)
  status        String   @default("OPEN") // OPEN, CLOSED
   
  // Relations
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store         Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cashTransactions CashTransaction[]
   
  @@index([tenant_id, status])
}

model CashTransaction {
  id            String   @id @default(uuid())
  tenant_id     String
  session_id    String
  amount        Decimal  @db.Decimal(12, 2) // Positive for cash in, negative for cash out
  type          String   // e.g., 'DROP', 'LOAN', 'PAYOUT', 'OTHER'
  description   String?
  created_at    DateTime @default(now())
   
  // Relations
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  session       CashierSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  tenant_id          String             @unique
  plan_id            String
  status             SubscriptionStatus @default(TRIALING)
  current_period_end DateTime
  
  // Relations
  tenant             Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan   @relation(fields: [plan_id], references: [id])
}
