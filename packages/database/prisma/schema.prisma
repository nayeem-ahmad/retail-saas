datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  ACCOUNTANT
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum SubscriptionPlanCode {
  FREE
  BASIC
  STANDARD
  PREMIUM
}

enum CustomerType {
  INDIVIDUAL
  ORGANIZATION
}

enum StorePermission {
  // Product & Catalog
  VIEW_PRODUCT_CATALOG
  EDIT_PRODUCTS
  EDIT_PRODUCT_PRICES
  EDIT_SUPPLIERS

  // Inventory
  CREATE_INVENTORY_MOVEMENTS
  CREATE_GOODS_TRANSFER
  APPROVE_GOODS_TRANSFER
  STOCK_TAKE

  // Transactions
  CREATE_SALE
  CREATE_PURCHASE
  CREATE_RETURN
  CREATE_SALES_ORDER
  CREATE_QUOTATION

  // Accounting
  VIEW_LEDGER
  CREATE_VOUCHER
  VIEW_FINANCIAL_REPORTS

  // Fund Transfers
  CREATE_FUND_TRANSFER
  APPROVE_FUND_TRANSFER

  // Multi-Store
  SWITCH_STORES
  VIEW_CONSOLIDATED_REPORTS

  // User Management
  MANAGE_USERS
  MANAGE_USER_STORE_ACCESS
}

enum PostingRuleEventType {
  sale
  sale_return
  purchase
  purchase_return
  inventory_adjustment
  fund_movement
}

enum PostingRuleConditionKey {
  payment_mode
  reason_type
  transfer_scope
  none
}

enum PostingEventStatus {
  pending
  posted
  failed
  skipped
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  name              String?
  token_version     Int       @default(0)
  email_verified_at DateTime?
  totp_secret       String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  // Relations
  tenantsOwned              Tenant[]                @relation("TenantOwner")
  tenantMembers             TenantUser[]
  cashierSessions           CashierSession[]
  storeAccess               UserStoreAccess[]
  storePermissions          UserStorePermission[]
  fundTransfersInitiated    FundTransfer[]          @relation("FundTransferInitiator")
  fundTransfersReceived     FundTransfer[]          @relation("FundTransferReceiver")
  auditLogs                 AuditLog[]
  passwordResetTokens       PasswordResetToken[]
  emailVerificationTokens   EmailVerificationToken[]
  sentInvitations           UserInvitation[]        @relation("InvitationSender")
  feedbacks                 Feedback[]
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model EmailVerificationToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model UserInvitation {
  id          String    @id @default(uuid())
  tenant_id   String
  email       String
  role        UserRole  @default(CASHIER)
  token_hash  String    @unique
  invited_by  String
  expires_at  DateTime
  accepted_at DateTime?
  created_at  DateTime  @default(now())

  tenant      Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("InvitationSender", fields: [invited_by], references: [id])

  @@index([tenant_id, email])
}

model AuditLog {
  id          String   @id @default(uuid())
  tenant_id   String?
  user_id     String?
  action      String
  entity      String
  entity_id   String?
  payload     Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  user        User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([tenant_id, entity, created_at])
  @@index([user_id, created_at])
  @@index([entity, entity_id])
}

model Tenant {
  id                   String   @id @default(uuid())
  name                 String
  owner_id             String
  created_at           DateTime @default(now())
  storefront_slug      String?  @unique
  storefront_enabled   Boolean  @default(false)
  storefront_banner    String?
  storefront_hero_image String?
  storefront_hero_headline String?
  brand_primary_color  String?
  brand_logo_url       String?
  brand_favicon_url    String?
  brand_business_name  String?
  default_vat_rate     Decimal? @db.Decimal(5, 2)  // e.g. 15.00 for 15% BD VAT
  vat_registration_no  String?                      // NBR VAT registration number
  business_tin         String?                      // Tax Identification Number
  loyalty_points_enabled Boolean  @default(false)
  loyalty_earn_rate      Decimal? @db.Decimal(8, 4)  // points per BDT (e.g. 1.0 = 1 point per ৳1)
  loyalty_redeem_rate    Decimal? @db.Decimal(8, 4)  // BDT value per point (e.g. 0.01 = 1 point = ৳0.01)
  loyalty_min_redeem     Int?                          // minimum points required to redeem

  sms_enabled          Boolean  @default(false)
  sms_on_sale          Boolean  @default(false)  // send SMS receipt after each sale
  sms_on_low_stock     Boolean  @default(false)  // send SMS for low stock alerts

  report_weekly_enabled  Boolean  @default(false)
  report_monthly_enabled Boolean  @default(false)
  report_email           String?  // override email for reports (defaults to owner email)

  // Relations
  owner      User     @relation("TenantOwner", fields: [owner_id], references: [id])
  stores     Store[]
  warehouses Warehouse[]
  users      TenantUser[]
  subscription TenantSubscription?
  billingEvents BillingEvent[]

  apiKeys         ApiKey[]
  deliveryOrders  DeliveryOrder[]
  products   Product[]
  productGroups ProductGroup[]
  productSubgroups ProductSubgroup[]
  productStocks ProductStock[]
  inventoryMovements InventoryMovement[]
  inventoryReasons InventoryReason[]
  inventorySettings InventorySettings?
  warehouseTransfers WarehouseTransfer[]
  inventoryShrinkages InventoryShrinkage[]
  stockTakeSessions StockTakeSession[]
  sales      Sale[]
  salesReturns SalesReturn[]
  purchaseReturns PurchaseReturn[]
  salesOrders SalesOrder[]
  quotations Quotation[]
  suppliers  Supplier[]
  purchases  Purchase[]
  customers  Customer[]
  customerGroups CustomerGroup[]
  territories    Territory[]
  accountGroups  AccountGroup[]
  accountSubgroups AccountSubgroup[]
  accounts Account[]
  voucherSequences VoucherSequence[]
  vouchers Voucher[]
  cashierSessions   CashierSession[]
  cashTransactions  CashTransaction[]
  userStoreAccess   UserStoreAccess[]
  userStorePermissions UserStorePermission[]
  productPrices     ProductPrice[]
  fundTransfers     FundTransfer[]
  postingRules      PostingRule[]
  postingEvents     PostingEvent[]
  warrantyClaims    WarrantyClaim[]
  invitations       UserInvitation[]
  feedbacks         Feedback[]
  storefrontOrders  StorefrontOrder[]
  bomRecipes      BomRecipe[]
  productionJobs  ProductionJob[]
  loyaltyTransactions LoyaltyTransaction[]
  discountCodes   DiscountCode[]
}

model TenantUser {
  id        String   @id @default(uuid())
  tenant_id String
  user_id   String
  role      UserRole @default(CASHIER)
  
  // Relations
  tenant    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id])
}

model Store {
  id        String   @id @default(uuid())
  tenant_id String
  name      String
  address   String?
  created_at DateTime @default(now())

  // Relations
  tenant          Tenant              @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sales           Sale[]
  salesReturns    SalesReturn[]
  purchaseReturns PurchaseReturn[]
  salesOrders     SalesOrder[]
  quotations      Quotation[]
  purchases       Purchase[]
  cashierSessions CashierSession[]
  warehouses      Warehouse[]
  userStoreAccess UserStoreAccess[]
  userStorePermissions UserStorePermission[]
  productPrices   ProductPrice[]
  fundTransfersSource      FundTransfer[] @relation("FundTransferSourceStore")
  fundTransfersDestination FundTransfer[] @relation("FundTransferDestinationStore")
  warrantyClaims  WarrantyClaim[]
}

model Warehouse {
  id         String   @id @default(uuid())
  tenant_id  String
  store_id   String
  name       String
  code       String
  is_default Boolean  @default(false)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store      Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  productStocks ProductStock[]
  inventoryMovements InventoryMovement[]
  transferSourceRows WarehouseTransfer[] @relation("TransferSourceWarehouse")
  transferDestinationRows WarehouseTransfer[] @relation("TransferDestinationWarehouse")
  shrinkageRows InventoryShrinkage[]
  stockTakeSessions StockTakeSession[]
  productWarehouseDefaults InventorySettings[] @relation("ProductWarehouseDefault")
  purchaseWarehouseDefaults InventorySettings[] @relation("PurchaseWarehouseDefault")
  salesWarehouseDefaults InventorySettings[] @relation("SalesWarehouseDefault")
  shrinkageWarehouseDefaults InventorySettings[] @relation("ShrinkageWarehouseDefault")
  transferSourceWarehouseDefaults InventorySettings[] @relation("TransferSourceWarehouseDefault")
  transferDestinationWarehouseDefaults InventorySettings[] @relation("TransferDestinationWarehouseDefault")

  @@unique([tenant_id, code])
  @@index([tenant_id, store_id])
}

model ProductGroup {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  description String?
  is_featured Boolean  @default(false)
  image_url  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  subgroups  ProductSubgroup[]
  products   Product[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
}

model ProductSubgroup {
  id         String   @id @default(uuid())
  tenant_id  String
  group_id   String
  name       String
  description String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  group      ProductGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  products   Product[]

  @@unique([group_id, name])
  @@index([tenant_id])
  @@index([group_id])
}

model Product {
  id          String   @id @default(uuid())
  tenant_id   String
  group_id    String?
  subgroup_id String?
  name        String
  sku         String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  compare_at_price Decimal? @db.Decimal(12, 2)  // original price for sale display
  is_featured Boolean  @default(false)
  vat_rate    Decimal? @db.Decimal(5, 2)  // product-specific VAT rate; null = use tenant default
  warranty_enabled Boolean @default(false)
  warranty_duration_days Int?
  reorder_level Int?
  safety_stock Int?
  lead_time_days Int?
  image_url   String?
  unit_type   String    @default("none")
  created_at  DateTime  @default(now())
  deleted_at  DateTime?

  // Relations
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  group       ProductGroup? @relation(fields: [group_id], references: [id])
  subgroup    ProductSubgroup? @relation(fields: [subgroup_id], references: [id])
  stocks      ProductStock[]
  inventoryMovements InventoryMovement[]
  transferItems WarehouseTransferItem[]
  shrinkageItems InventoryShrinkageItem[]
  stockTakeLines StockTakeCountLine[]
  saleItems   SaleItem[]
  returnItems SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  orderItems  SalesOrderItem[]
  quoteItems  QuotationItem[]
  purchaseItems PurchaseItem[]
  prices      ProductPrice[]
  warrantyClaims WarrantyClaim[]
  storefrontOrderItems StorefrontOrderItem[]
  bomRecipe    BomRecipe?
  bomComponents BomComponent[] @relation("BomComponent")

  @@unique([tenant_id, sku])
  @@index([tenant_id, group_id])
  @@index([tenant_id, subgroup_id])
  @@index([tenant_id, deleted_at])
  @@index([tenant_id, reorder_level])
}

model ProductStock {
  id          String   @id @default(uuid())
  tenant_id   String
  product_id  String
  warehouse_id String
  quantity    Int      @default(0)
  
  // Relations
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  warehouse   Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, product_id, warehouse_id])
  @@index([tenant_id, warehouse_id])
}

model ProductSerial {
  id               String   @id @default(uuid())
  tenant_id        String
  store_id         String?
  product_id       String
  serial_number    String
  status           String   @default("IN_STOCK")
  source_type      String?
  source_id        String?
  claim_reference  String?
  sold_at          DateTime?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@unique([tenant_id, product_id, serial_number])
  @@index([tenant_id, serial_number])
  @@index([tenant_id, status])
  @@index([tenant_id, product_id, status])
}

model InventoryMovement {
  id             String   @id @default(uuid())
  tenant_id      String
  product_id     String
  warehouse_id   String
  movement_type  String
  reference_type String?
  reference_id   String?
  quantity_delta Int
  balance_after  Int?
  unit_cost      Decimal? @db.Decimal(12, 2)
  note           String?
  created_at     DateTime @default(now())

  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  warehouse      Warehouse @relation(fields: [warehouse_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([tenant_id, warehouse_id, created_at])
  @@index([tenant_id, product_id, created_at])
  @@index([tenant_id, movement_type])
}

model InventoryReason {
  id            String   @id @default(uuid())
  tenant_id     String
  type          String
  code          String
  label         String
  is_system     Boolean  @default(false)
  is_active     Boolean  @default(true)
  display_order Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  shrinkageRows InventoryShrinkage[]
  stockTakeLines StockTakeCountLine[]

  @@unique([tenant_id, type, code])
  @@index([tenant_id, type, is_active])
}

model InventorySettings {
  id                                String   @id @default(uuid())
  tenant_id                         String   @unique
  default_product_warehouse_id      String?
  default_purchase_warehouse_id     String?
  default_sales_warehouse_id        String?
  default_shrinkage_warehouse_id    String?
  default_transfer_source_warehouse_id String?
  default_transfer_destination_warehouse_id String?
  default_reorder_level             Int      @default(10)
  default_safety_stock              Int      @default(0)
  default_lead_time_days            Int      @default(0)
  discrepancy_approval_threshold    Int      @default(25)
  created_at                        DateTime @default(now())
  updated_at                        DateTime @updatedAt

  tenant                            Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  defaultProductWarehouse           Warehouse? @relation("ProductWarehouseDefault", fields: [default_product_warehouse_id], references: [id])
  defaultPurchaseWarehouse          Warehouse? @relation("PurchaseWarehouseDefault", fields: [default_purchase_warehouse_id], references: [id])
  defaultSalesWarehouse             Warehouse? @relation("SalesWarehouseDefault", fields: [default_sales_warehouse_id], references: [id])
  defaultShrinkageWarehouse         Warehouse? @relation("ShrinkageWarehouseDefault", fields: [default_shrinkage_warehouse_id], references: [id])
  defaultTransferSourceWarehouse    Warehouse? @relation("TransferSourceWarehouseDefault", fields: [default_transfer_source_warehouse_id], references: [id])
  defaultTransferDestinationWarehouse Warehouse? @relation("TransferDestinationWarehouseDefault", fields: [default_transfer_destination_warehouse_id], references: [id])

  @@index([default_product_warehouse_id])
  @@index([default_purchase_warehouse_id])
  @@index([default_sales_warehouse_id])
  @@index([default_shrinkage_warehouse_id])
  @@index([default_transfer_source_warehouse_id])
  @@index([default_transfer_destination_warehouse_id])
}

model WarehouseTransfer {
  id                       String   @id @default(uuid())
  tenant_id                String
  transfer_number          String
  source_warehouse_id      String
  destination_warehouse_id String
  status                   String   @default("DRAFT")
  notes                    String?
  sent_at                  DateTime?
  received_at              DateTime?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  // Cross-branch fields
  source_store_id          String?
  destination_store_id     String?
  is_cross_branch          Boolean  @default(false)
  requires_approval        Boolean  @default(false)
  approved_by              String?
  approval_date            DateTime?

  tenant                   Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sourceWarehouse          Warehouse @relation("TransferSourceWarehouse", fields: [source_warehouse_id], references: [id])
  destinationWarehouse     Warehouse @relation("TransferDestinationWarehouse", fields: [destination_warehouse_id], references: [id])
  items                    WarehouseTransferItem[]

  @@unique([tenant_id, transfer_number])
  @@index([tenant_id, status, created_at])
  @@index([tenant_id, source_warehouse_id])
  @@index([tenant_id, destination_warehouse_id])
  @@index([tenant_id, is_cross_branch])
}

model WarehouseTransferItem {
  id                String   @id @default(uuid())
  transfer_id       String
  product_id        String
  quantity_sent     Int
  quantity_received Int      @default(0)
  note              String?

  transfer          WarehouseTransfer @relation(fields: [transfer_id], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [product_id], references: [id])

  @@unique([transfer_id, product_id])
}

model InventoryShrinkage {
  id               String   @id @default(uuid())
  tenant_id        String
  warehouse_id     String
  reason_id        String
  reference_number String
  notes            String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant           Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  warehouse        Warehouse       @relation(fields: [warehouse_id], references: [id])
  reason           InventoryReason @relation(fields: [reason_id], references: [id])
  items            InventoryShrinkageItem[]

  @@unique([tenant_id, reference_number])
  @@index([tenant_id, warehouse_id, created_at])
  @@index([tenant_id, reason_id])
}

model InventoryShrinkageItem {
  id           String   @id @default(uuid())
  shrinkage_id String
  product_id   String
  quantity     Int
  unit_cost    Decimal? @db.Decimal(12, 2)
  note         String?

  shrinkage    InventoryShrinkage @relation(fields: [shrinkage_id], references: [id], onDelete: Cascade)
  product      Product            @relation(fields: [product_id], references: [id])

  @@unique([shrinkage_id, product_id])
}

model StockTakeSession {
  id             String   @id @default(uuid())
  tenant_id      String
  warehouse_id   String
  session_number String
  status         String   @default("DRAFT")
  notes          String?
  started_at     DateTime @default(now())
  posted_at      DateTime?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  warehouse      Warehouse @relation(fields: [warehouse_id], references: [id])
  lines          StockTakeCountLine[]

  @@unique([tenant_id, session_number])
  @@index([tenant_id, warehouse_id, status])
  @@index([tenant_id, created_at])
}

model StockTakeCountLine {
  id                String   @id @default(uuid())
  session_id        String
  product_id        String
  expected_quantity Int
  counted_quantity  Int?
  variance_quantity Int?
  reason_id         String?
  note              String?

  session           StockTakeSession  @relation(fields: [session_id], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [product_id], references: [id])
  reason            InventoryReason?  @relation(fields: [reason_id], references: [id])

  @@unique([session_id, product_id])
  @@index([session_id, variance_quantity])
}

model Supplier {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  phone       String?
  email       String?
  address     String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?

  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  purchases   Purchase[]
  purchaseReturns PurchaseReturn[]

  @@unique([tenant_id, name])
}

model Purchase {
  id              String   @id @default(uuid())
  tenant_id       String
  store_id        String
  supplier_id     String?
  purchase_number String
  subtotal_amount Decimal  @default(0) @db.Decimal(12, 2)
  tax_amount      Decimal  @default(0) @db.Decimal(12, 2)
  discount_amount Decimal  @default(0) @db.Decimal(12, 2)
  freight_amount  Decimal  @default(0) @db.Decimal(12, 2)
  total_amount    Decimal  @default(0) @db.Decimal(12, 2)
  notes           String?
  created_at      DateTime @default(now())

  tenant          Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store           Store     @relation(fields: [store_id], references: [id])
  supplier        Supplier? @relation(fields: [supplier_id], references: [id])
  items           PurchaseItem[]
  returns         PurchaseReturn[]

  @@unique([tenant_id, purchase_number])
  @@index([tenant_id, created_at])
  @@index([tenant_id, store_id])
}

model PurchaseItem {
  id            String   @id @default(uuid())
  purchase_id   String
  product_id    String
  quantity      Int
  unit_cost     Decimal  @db.Decimal(12, 2)
  line_total    Decimal  @db.Decimal(12, 2)

  purchase      Purchase @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [product_id], references: [id])
  returnItems   PurchaseReturnItem[]
}

model PurchaseReturn {
  id               String   @id @default(uuid())
  tenant_id        String
  store_id         String
  purchase_id      String
  supplier_id      String?
  return_number    String
  reference_number String?
  total_amount     Decimal  @default(0) @db.Decimal(12, 2)
  notes            String?
  status           String   @default("RECORDED")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store            Store     @relation(fields: [store_id], references: [id])
  purchase         Purchase  @relation(fields: [purchase_id], references: [id])
  supplier         Supplier? @relation(fields: [supplier_id], references: [id])
  items            PurchaseReturnItem[]

  @@unique([tenant_id, return_number])
}

model PurchaseReturnItem {
  id               String   @id @default(uuid())
  return_id        String
  purchase_item_id String
  product_id       String
  quantity         Int
  unit_cost        Decimal  @db.Decimal(12, 2)
  line_total       Decimal  @db.Decimal(12, 2)

  purchaseReturn   PurchaseReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)
  purchaseItem     PurchaseItem   @relation(fields: [purchase_item_id], references: [id])
  product          Product        @relation(fields: [product_id], references: [id])
}

model Sale {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  serial_number  String
  total_amount   Decimal  @db.Decimal(12, 2)
  amount_paid    Decimal    @default(0) @db.Decimal(12, 2)
  status         String
  note           String?
  created_at     DateTime @default(now())

  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  customer_id    String?
  customer       Customer? @relation(fields: [customer_id], references: [id])
  items          SaleItem[]
  payments       PaymentRecord[]
  returns        SalesReturn[]
  warrantyClaims WarrantyClaim[]
  deliveryOrders DeliveryOrder[]

  @@unique([tenant_id, serial_number])
  @@index([tenant_id, created_at])
  @@index([tenant_id, store_id])
  @@index([tenant_id, customer_id])
}

model Customer {
  id                   String        @id @default(uuid())
  tenant_id            String
  customer_code        String
  name                 String
  phone                String
  email                String?
  address              String?
  profile_pic_url      String?
  customer_type        CustomerType  @default(INDIVIDUAL)
  customer_group_id    String?
  territory_id         String?
  credit_limit         Decimal?      @db.Decimal(12, 2)
  default_discount_pct Decimal?      @db.Decimal(5, 2)
  total_spent          Decimal       @default(0) @db.Decimal(12, 2)
  nid                  String?
  segment_category     String        @default("Regular")
  loyalty_points       Int           @default(0)
  created_at           DateTime      @default(now())
  deleted_at           DateTime?

  // Relations
  tenant           Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customerGroup    CustomerGroup? @relation(fields: [customer_group_id], references: [id])
  territory        Territory?     @relation(fields: [territory_id], references: [id])
  sales            Sale[]
  salesOrders      SalesOrder[]
  quotations       Quotation[]
  warrantyClaims   WarrantyClaim[]
  loyaltyTransactions LoyaltyTransaction[]

  @@unique([tenant_id, phone])
  @@unique([tenant_id, customer_code])
  @@index([tenant_id, deleted_at])
  @@index([tenant_id, email])
}

model CustomerGroup {
  id                   String   @id @default(uuid())
  tenant_id            String
  name                 String
  description          String?
  default_discount_pct Decimal? @db.Decimal(5, 2)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  // Relations
  tenant    Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  customers Customer[]

  @@unique([tenant_id, name])
}

model Territory {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  parent_id   String?
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  tenant    Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  parent    Territory?  @relation("TerritoryHierarchy", fields: [parent_id], references: [id])
  children  Territory[] @relation("TerritoryHierarchy")
  customers Customer[]

  @@unique([tenant_id, name, parent_id])
}

model AccountGroup {
  id         String   @id @default(uuid())
  tenant_id  String
  name       String
  type       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  subgroups  AccountSubgroup[]
  accounts   Account[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@map("account_groups")
}

model AccountSubgroup {
  id         String   @id @default(uuid())
  tenant_id  String
  group_id   String
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant     Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  group      AccountGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  accounts   Account[]

  @@unique([group_id, name])
  @@index([tenant_id])
  @@index([group_id])
  @@map("account_subgroups")
}

model Account {
  id          String   @id @default(uuid())
  tenant_id   String
  group_id    String
  subgroup_id String?
  name        String
  code        String?
  type        String
  category    String   @default("general")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  group       AccountGroup    @relation(fields: [group_id], references: [id])
  subgroup    AccountSubgroup? @relation(fields: [subgroup_id], references: [id])
  voucherDetails VoucherDetail[]
  debitPostingRules PostingRule[] @relation("PostingRuleDebitAccount")
  creditPostingRules PostingRule[] @relation("PostingRuleCreditAccount")

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@index([group_id])
  @@index([subgroup_id])
  @@index([tenant_id, type])
  @@index([tenant_id, category])
  @@map("accounts")
}

model PostingRule {
  id                String                  @id @default(cuid())
  tenant_id         String
  event_type        PostingRuleEventType
  condition_key     PostingRuleConditionKey @default(none)
  condition_value   String?
  debit_account_id  String
  credit_account_id String
  priority          Int                     @default(100)
  is_active         Boolean                 @default(true)
  created_at        DateTime                @default(now())
  updated_at        DateTime                @updatedAt

  tenant       Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  debitAccount Account @relation("PostingRuleDebitAccount", fields: [debit_account_id], references: [id], onDelete: Restrict)
  creditAccount Account @relation("PostingRuleCreditAccount", fields: [credit_account_id], references: [id], onDelete: Restrict)

  @@index([tenant_id, event_type, is_active])
  @@index([tenant_id, condition_key, condition_value])
  @@index([tenant_id, debit_account_id])
  @@index([tenant_id, credit_account_id])
  @@map("posting_rules")
}

model VoucherSequence {
  id           String   @id
  tenant_id    String
  voucher_type String
  prefix       String
  next_number  Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, voucher_type])
  @@index([tenant_id])
  @@map("voucher_sequences")
}

model Voucher {
  id               String   @id @default(uuid())
  tenant_id        String
  voucher_number   String
  voucher_type     String
  source_module    String?
  source_type      String?
  source_id        String?
  idempotency_key  String?
  description      String?
  reference_number String?
  date             DateTime @default(now())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  details          VoucherDetail[]
  postingEvents    PostingEvent[]
  fundTransfersSource      FundTransfer[] @relation("FundTransferSourceVoucher")
  fundTransfersDestination FundTransfer[] @relation("FundTransferDestinationVoucher")

  @@unique([tenant_id, voucher_number])
  @@index([tenant_id])
  @@index([tenant_id, voucher_type])
  @@index([tenant_id, source_module, source_type, source_id])
  @@index([date])
  @@map("vouchers")
}

model PostingEvent {
  id               String            @id @default(cuid())
  tenant_id        String
  event_type       PostingRuleEventType
  source_module    String
  source_type      String
  source_id        String
  idempotency_key  String
  status           PostingEventStatus @default(pending)
  voucher_id       String?
  attempt_count    Int               @default(0)
  last_error       String?
  last_attempt_at  DateTime?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  tenant           Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  voucher          Voucher?          @relation(fields: [voucher_id], references: [id], onDelete: SetNull)

  @@unique([tenant_id, idempotency_key])
  @@index([tenant_id, status, updated_at])
  @@index([tenant_id, source_module, source_type, source_id])
  @@map("posting_events")
}

model VoucherDetail {
  id            String   @id @default(uuid())
  voucher_id    String
  account_id    String
  debit_amount  Decimal  @default(0) @db.Decimal(12, 2)
  credit_amount Decimal  @default(0) @db.Decimal(12, 2)
  comment       String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  voucher       Voucher  @relation(fields: [voucher_id], references: [id], onDelete: Cascade)
  account       Account  @relation(fields: [account_id], references: [id])

  @@index([voucher_id])
  @@index([account_id])
  @@map("voucher_details")
}

model PaymentRecord {
  id             String   @id @default(uuid())
  sale_id        String
  payment_method String
  amount         Decimal  @db.Decimal(12, 2)
  created_at     DateTime @default(now())
  
  // Relations
  sale           Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
}

model SaleItem {
  id            String   @id @default(uuid())
  sale_id       String
  product_id    String
  quantity      Int
  price_at_sale Decimal  @db.Decimal(12, 2)
  
  // Relations
  sale          Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [product_id], references: [id])
  returns       SalesReturnItem[]

  @@index([sale_id])
}

model SalesReturn {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  sale_id        String
  return_number  String
  total_refund   Decimal  @db.Decimal(12, 2)
  reason         String?
  status         String   @default("COMPLETED")
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  sale           Sale     @relation(fields: [sale_id], references: [id])
  items          SalesReturnItem[]

  @@unique([tenant_id, return_number])
}

model SalesReturnItem {
  id             String   @id @default(uuid())
  return_id      String
  sale_item_id   String
  product_id     String
  quantity       Int
  refund_amount  Decimal  @db.Decimal(12, 2)
  
  // Relations
  return         SalesReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)
  sale_item      SaleItem    @relation(fields: [sale_item_id], references: [id])
  product        Product     @relation(fields: [product_id], references: [id])
}

model SalesOrder {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  customer_id    String?
  order_number   String
  total_amount   Decimal  @db.Decimal(12, 2)
  amount_paid    Decimal    @default(0) @db.Decimal(12, 2)
  status         String   @default("DRAFT") // DRAFT, CONFIRMED, PROCESSING, DELIVERED, CANCELLED
  payment_status String   @default("UNPAID") // UNPAID, PARTIAL, PAID
  delivery_date  DateTime?
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  customer       Customer? @relation(fields: [customer_id], references: [id])
  items          SalesOrderItem[]
  deposits       OrderDeposit[]

  @@unique([tenant_id, order_number])
  @@index([tenant_id, status])
  @@index([tenant_id, created_at])
}

model SalesOrderItem {
  id             String   @id @default(uuid())
  order_id       String
  product_id     String
  quantity       Int
  price_at_order Decimal  @db.Decimal(12, 2)
  
  // Relations
  order          SalesOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product        Product    @relation(fields: [product_id], references: [id])
}

model OrderDeposit {
  id             String   @id @default(uuid())
  order_id       String
  amount         Decimal  @db.Decimal(12, 2)
  payment_method String
  created_at     DateTime @default(now())
  
  // Relations
  order          SalesOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model Quotation {
  id                String   @id @default(uuid())
  tenant_id         String
  store_id          String
  customer_id       String?
  quote_number      String
  total_amount      Decimal  @db.Decimal(12, 2)
  status            String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED, REVISED
  valid_until       DateTime?
  version           Int      @default(1)
  original_quote_id String?
  notes             String?
  created_at        DateTime @default(now())
  
  // Relations
  tenant            Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store             Store    @relation(fields: [store_id], references: [id])
  customer          Customer? @relation(fields: [customer_id], references: [id])
  items             QuotationItem[]

  @@unique([tenant_id, quote_number, version])
}

model QuotationItem {
  id             String   @id @default(uuid())
  quotation_id   String
  product_id     String
  quantity       Int
  unit_price     Decimal  @db.Decimal(12, 2)
  
  // Relations
  quotation      Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [product_id], references: [id])
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  code          SubscriptionPlanCode @unique
  name          String
  description   String?
  monthly_price Decimal  @db.Decimal(12, 2)
  yearly_price  Decimal? @db.Decimal(12, 2)
  features_json Json     @default("{}")
  is_active     Boolean  @default(true)
  subscriptions TenantSubscription[]
}

model CashierSession {
  id            String   @id @default(uuid())
  tenant_id     String
  store_id      String
  user_id       String   // The cashier/user who opened the session
  opened_at     DateTime @default(now())
  closed_at     DateTime?
  opening_cash  Decimal  @default(0) @db.Decimal(12, 2)
  closing_cash  Decimal  @default(0) @db.Decimal(12, 2)
  status        String   @default("OPEN") // OPEN, CLOSED
   
  // Relations
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store         Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  cashTransactions CashTransaction[]
   
  @@index([tenant_id, status])
}

model CashTransaction {
  id            String   @id @default(uuid())
  tenant_id     String
  session_id    String
  amount        Decimal  @db.Decimal(12, 2) // Positive for cash in, negative for cash out
  type          String   // e.g., 'DROP', 'LOAN', 'PAYOUT', 'OTHER'
  description   String?
  created_at    DateTime @default(now())
   
  // Relations
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  session       CashierSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  tenant_id          String             @unique
  plan_id            String
  status             SubscriptionStatus @default(TRIALING)
  current_period_start DateTime         @default(now())
  current_period_end DateTime
  cancel_at_period_end Boolean          @default(false)
  provider_name      String?
  provider_customer_ref String?
  provider_subscription_ref String?
  
  // Relations
  tenant             Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan   @relation(fields: [plan_id], references: [id])

  @@index([plan_id, status])
}

model BillingEvent {
  id                 String   @id @default(uuid())
  tenant_id          String
  provider_name      String
  external_event_id  String
  event_type         String
  status             String
  reference_id       String?
  amount             Decimal? @db.Decimal(12, 2)
  currency           String?
  payload            Json
  created_at         DateTime @default(now())

  tenant             Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([provider_name, external_event_id])
  @@index([tenant_id, created_at])
  @@index([tenant_id, provider_name])
}

// ── Multi-Store Access & Permission Models ───────────────────────────────────

model UserStoreAccess {
  id           String   @id @default(uuid())
  user_id      String
  store_id     String
  tenant_id    String
  // STORE_ONLY = access to exactly this one context
  // MULTI_STORE_CAPABLE = can switch between assigned stores
  access_level String   @default("STORE_ONLY")
  created_at   DateTime @default(now())

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store        Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([user_id, store_id])
  @@index([tenant_id, store_id])
  @@index([user_id, tenant_id])
}

model UserStorePermission {
  id           String          @id @default(uuid())
  user_id      String
  store_id     String
  tenant_id    String
  permission   StorePermission
  granted_by   String
  granted_at   DateTime        @default(now())

  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store        Store           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  tenant       Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([user_id, store_id, permission])
  @@index([user_id, store_id])
  @@index([tenant_id, store_id, permission])
}

// Store-specific product price overrides.
// store_id = NULL means base price (default for all stores).
model ProductPrice {
  id             String    @id @default(uuid())
  tenant_id      String
  product_id     String
  store_id       String?
  price          Decimal   @db.Decimal(12, 2)
  cost           Decimal?  @db.Decimal(12, 2)
  effective_from DateTime  @default(now())
  effective_to   DateTime?
  created_at     DateTime  @default(now())

  tenant         Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  store          Store?    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, product_id, store_id])
  @@index([product_id, store_id, effective_from])
}

model FundTransfer {
  id                    String    @id @default(uuid())
  tenant_id             String
  source_store_id       String
  destination_store_id  String
  amount                Decimal   @db.Decimal(12, 2)
  method                String    @default("CASH")  // CASH, CHECK, BANK_TRANSFER
  description           String?
  // INITIATED, IN_TRANSIT, RECEIVED, CANCELLED
  status                String    @default("INITIATED")
  initiated_by          String
  received_by           String?
  // Voucher linkage for accounting integration
  source_voucher_id     String?
  destination_voucher_id String?
  created_at            DateTime  @default(now())
  received_at           DateTime?

  tenant                Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sourceStore           Store     @relation("FundTransferSourceStore", fields: [source_store_id], references: [id])
  destinationStore      Store     @relation("FundTransferDestinationStore", fields: [destination_store_id], references: [id])
  initiatedByUser       User      @relation("FundTransferInitiator", fields: [initiated_by], references: [id])
  receivedByUser        User?     @relation("FundTransferReceiver", fields: [received_by], references: [id])
  sourceVoucher         Voucher?  @relation("FundTransferSourceVoucher", fields: [source_voucher_id], references: [id])
  destinationVoucher    Voucher?  @relation("FundTransferDestinationVoucher", fields: [destination_voucher_id], references: [id])

  @@index([tenant_id, status, created_at])
  @@index([tenant_id, source_store_id])
  @@index([tenant_id, destination_store_id])
}

// Warranty claim statuses: SUBMITTED, APPROVED, REJECTED, REPAIRED, REPLACED, COMPLETED
model WarrantyClaim {
  id                       String    @id @default(uuid())
  tenant_id                String
  store_id                 String
  claim_number             String
  serial_number            String
  product_id               String
  sale_id                  String?
  customer_id              String?
  status                   String    @default("SUBMITTED")
  reason                   String
  description              String?
  resolution_notes         String?
  replacement_serial_number String?
  resolved_at              DateTime?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store            Store     @relation(fields: [store_id], references: [id])
  sale             Sale?     @relation(fields: [sale_id], references: [id])
  customer         Customer? @relation(fields: [customer_id], references: [id])
  product          Product   @relation(fields: [product_id], references: [id])

  @@unique([tenant_id, claim_number])
  @@index([tenant_id, status, created_at])
  @@index([tenant_id, serial_number])
  @@index([tenant_id, product_id])
  @@index([tenant_id, customer_id])
}

model Feedback {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  type       String   // 'bug' | 'feature' | 'general'
  message    String
  page       String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("feedbacks")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  key_hash   String    @unique  // SHA-256 hash of the actual key
  key_prefix String             // first 8 chars for display (e.g. "rsk_live")
  last_used  DateTime?
  created_at DateTime  @default(now())
  revoked_at DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model StorefrontOrder {
  id            String   @id @default(cuid())
  tenantId      String
  customerName  String
  customerEmail String
  customerPhone String?
  items         StorefrontOrderItem[]
  totalAmount   Decimal  @db.Decimal(12, 2)
  status        String   @default("PENDING")
  notes         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("storefront_orders")
}

model StorefrontOrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  quantity     Int
  priceAtOrder Decimal @db.Decimal(12, 2)

  order   StorefrontOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@map("storefront_order_items")
}

model DeliveryOrder {
  id              String    @id @default(cuid())
  tenantId        String
  saleId          String?
  customerName    String
  customerPhone   String?
  deliveryAddress String
  driverName      String?
  driverPhone     String?
  status          String    @default("PENDING")
  notes           String?
  scheduledAt     DateTime?
  deliveredAt     DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   Sale?  @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("delivery_orders")
}

// Bill of Materials: defines what components go into making 1 unit of a product
model BomRecipe {
  id           String   @id @default(cuid())
  tenantId     String
  productId    String   @unique  // the manufactured/output product
  outputQty    Int      @default(1)
  notes        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
  components BomComponent[]
  productionJobs ProductionJob[]

  @@index([tenantId])
  @@map("bom_recipes")
}

model BomComponent {
  id        String   @id @default(cuid())
  recipeId  String
  productId String   // the raw material / component product
  quantity  Decimal  @db.Decimal(12, 4)

  recipe    BomRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product   Product   @relation("BomComponent", fields: [productId], references: [id])

  @@map("bom_components")
}

// A production run: manufacture N units of a product
model ProductionJob {
  id           String   @id @default(cuid())
  tenantId     String
  recipeId     String
  productId    String   // output product (denormalised for easy querying)
  quantity     Int
  status       String   @default("DRAFT")  // DRAFT | IN_PROGRESS | COMPLETED | CANCELLED
  notes        String?
  startedAt    DateTime?
  completedAt  DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipe  BomRecipe @relation(fields: [recipeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("production_jobs")
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  saleId      String?
  type        String   // EARN | REDEEM | ADJUST
  points      Int      // positive = earn, negative = redeem/adjust
  description String?
  created_at  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([customerId])
  @@map("loyalty_transactions")
}

model DiscountCode {
  id           String    @id @default(cuid())
  tenantId     String
  code         String
  name         String
  type         String    // PERCENTAGE | FIXED
  value        Decimal   @db.Decimal(10, 2)  // percent (0-100) or fixed BDT amount
  min_purchase Decimal?  @db.Decimal(12, 2)  // minimum cart total to apply
  max_discount Decimal?  @db.Decimal(12, 2)  // cap for PERCENTAGE type
  usage_limit  Int?                           // null = unlimited
  used_count   Int       @default(0)
  valid_from   DateTime?
  valid_until  DateTime?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, is_active])
  @@map("discount_codes")
}
