  paymentRecords PaymentRecord[]

  @@unique([tenant_id, name])
  @@index([tenant_id])
  @@index([group_id])
  @@index([subgroup_id])
  @@index([tenant_id, type])
  @@index([tenant_id, category])
  @@map("accounts")
