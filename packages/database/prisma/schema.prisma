datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  MANAGER
  CASHIER
  ACCOUNTANT
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String
  name          String?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  
  // Relations
  tenantsOwned  Tenant[]     @relation("TenantOwner")
  tenantMembers TenantUser[]
}

model Tenant {
  id         String   @id @default(uuid())
  name       String
  owner_id   String
  created_at DateTime @default(now())
  
  // Relations
  owner      User     @relation("TenantOwner", fields: [owner_id], references: [id])
  stores     Store[]
  users      TenantUser[]
  subscription TenantSubscription?
  
  products   Product[]
  productStocks ProductStock[]
  sales      Sale[]
  salesReturns SalesReturn[]
  salesOrders SalesOrder[]
  quotations Quotation[]
  customers  Customer[]
}

model TenantUser {
  id        String   @id @default(uuid())
  tenant_id String
  user_id   String
  role      UserRole @default(CASHIER)
  
  // Relations
  tenant    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, user_id])
}

model Store {
  id        String   @id @default(uuid())
  tenant_id String
  name      String
  address   String?
  created_at DateTime @default(now())
  
  // Relations
  tenant    Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sales     Sale[]
  salesReturns SalesReturn[]
  salesOrders SalesOrder[]
  quotations Quotation[]
}

model Product {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  sku         String?
  price       Decimal  @default(0) @db.Decimal(12, 2)
  image_url   String?
  created_at  DateTime @default(now())
  
  // Relations
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  stocks      ProductStock[]
  saleItems   SaleItem[]
  returnItems SalesReturnItem[]
  orderItems  SalesOrderItem[]
  quoteItems  QuotationItem[]

  @@unique([tenant_id, sku])
}

model ProductStock {
  id          String   @id @default(uuid())
  tenant_id   String
  product_id  String
  quantity    Int      @default(0)
  
  // Relations
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id]) // Simplification for v0.1 (one stock record per product)
}

model Sale {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  serial_number  String
  total_amount   Decimal  @db.Decimal(12, 2)
  amount_paid    Decimal    @default(0) @db.Decimal(12, 2)
  status         String
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  customer_id    String?
  customer       Customer? @relation(fields: [customer_id], references: [id])
  items          SaleItem[]
  payments       PaymentRecord[]
  returns        SalesReturn[]

  @@unique([tenant_id, serial_number])
}

model Customer {
  id               String   @id @default(uuid())
  tenant_id        String
  name             String
  phone            String
  email            String?
  address          String?
  total_spent      Decimal  @default(0) @db.Decimal(12, 2)
  segment_category String   @default("Regular")
  created_at       DateTime @default(now())

  // Relations
  tenant           Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sales            Sale[]
  salesOrders      SalesOrder[]
  quotations       Quotation[]

  @@unique([tenant_id, phone])
}

model PaymentRecord {
  id             String   @id @default(uuid())
  sale_id        String
  payment_method String
  amount         Decimal  @db.Decimal(12, 2)
  created_at     DateTime @default(now())
  
  // Relations
  sale           Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
}

model SaleItem {
  id            String   @id @default(uuid())
  sale_id       String
  product_id    String
  quantity      Int
  price_at_sale Decimal  @db.Decimal(12, 2)
  
  // Relations
  sale          Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [product_id], references: [id])
  returns       SalesReturnItem[]
}

model SalesReturn {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  sale_id        String
  return_number  String
  total_refund   Decimal  @db.Decimal(12, 2)
  reason         String?
  status         String   @default("COMPLETED")
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  sale           Sale     @relation(fields: [sale_id], references: [id])
  items          SalesReturnItem[]

  @@unique([tenant_id, return_number])
}

model SalesReturnItem {
  id             String   @id @default(uuid())
  return_id      String
  sale_item_id   String
  product_id     String
  quantity       Int
  refund_amount  Decimal  @db.Decimal(12, 2)
  
  // Relations
  return         SalesReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)
  sale_item      SaleItem    @relation(fields: [sale_item_id], references: [id])
  product        Product     @relation(fields: [product_id], references: [id])
}

model SalesOrder {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  customer_id    String?
  order_number   String
  total_amount   Decimal  @db.Decimal(12, 2)
  amount_paid    Decimal    @default(0) @db.Decimal(12, 2)
  status         String   @default("DRAFT") // DRAFT, CONFIRMED, PROCESSING, DELIVERED, CANCELLED
  payment_status String   @default("UNPAID") // UNPAID, PARTIAL, PAID
  delivery_date  DateTime?
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  customer       Customer? @relation(fields: [customer_id], references: [id])
  items          SalesOrderItem[]
  deposits       OrderDeposit[]

  @@unique([tenant_id, order_number])
}

model SalesOrderItem {
  id             String   @id @default(uuid())
  order_id       String
  product_id     String
  quantity       Int
  price_at_order Decimal  @db.Decimal(12, 2)
  
  // Relations
  order          SalesOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product        Product    @relation(fields: [product_id], references: [id])
}

model OrderDeposit {
  id             String   @id @default(uuid())
  order_id       String
  amount         Decimal  @db.Decimal(12, 2)
  payment_method String
  created_at     DateTime @default(now())
  
  // Relations
  order          SalesOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model Quotation {
  id                String   @id @default(uuid())
  tenant_id         String
  store_id          String
  customer_id       String?
  quote_number      String
  total_amount      Decimal  @db.Decimal(12, 2)
  status            String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED, REVISED
  valid_until       DateTime?
  version           Int      @default(1)
  original_quote_id String?
  notes             String?
  created_at        DateTime @default(now())
  
  // Relations
  tenant            Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store             Store    @relation(fields: [store_id], references: [id])
  customer          Customer? @relation(fields: [customer_id], references: [id])
  items             QuotationItem[]

  @@unique([tenant_id, quote_number, version])
}

model QuotationItem {
  id             String   @id @default(uuid())
  quotation_id   String
  product_id     String
  quantity       Int
  unit_price     Decimal  @db.Decimal(12, 2)
  
  // Relations
  quotation      Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [product_id], references: [id])
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String
  monthly_price Decimal  @db.Decimal(12, 2)
  features_json Json     @default("{}")
  is_active     Boolean  @default(true)
  subscriptions TenantSubscription[]
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  tenant_id          String             @unique
  plan_id            String
  status             SubscriptionStatus @default(TRIALING)
  current_period_end DateTime
  
  // Relations
  tenant             Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan   @relation(fields: [plan_id], references: [id])
}
