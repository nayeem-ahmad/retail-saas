  is_active         Boolean                 @default(true)
  created_at        DateTime                @default(now())
  updated_at        DateTime                @updatedAt

  tenant       Tenant  @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  debitAccount Account @relation("PostingRuleDebitAccount", fields: [debit_account_id], references: [id], onDelete: Restrict)
  creditAccount Account @relation("PostingRuleCreditAccount", fields: [credit_account_id], references: [id], onDelete: Restrict)

  @@index([tenant_id, event_type, is_active])
  @@index([tenant_id, condition_key, condition_value])
  @@index([tenant_id, debit_account_id])
  @@index([tenant_id, credit_account_id])
  @@map("posting_rules")
}

model VoucherSequence {
  id           String   @id
  tenant_id    String
  voucher_type String
  prefix       String
  next_number  Int      @default(1)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, voucher_type])
  @@index([tenant_id])
  @@map("voucher_sequences")
}

model Voucher {
  id               String   @id @default(uuid())
  tenant_id        String
  voucher_number   String
  voucher_type     String
  source_module    String?
  source_type      String?
  source_id        String?
  idempotency_key  String?
  description      String?
  reference_number String?
  date             DateTime @default(now())
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  details          VoucherDetail[]
  postingEvents    PostingEvent[]
  fundTransfersSource      FundTransfer[] @relation("FundTransferSourceVoucher")
  fundTransfersDestination FundTransfer[] @relation("FundTransferDestinationVoucher")

  @@unique([tenant_id, voucher_number])
  @@index([tenant_id])
  @@index([tenant_id, voucher_type])
  @@index([tenant_id, source_module, source_type, source_id])
  @@index([date])
  @@map("vouchers")
}

model PostingEvent {
  id               String            @id @default(cuid())
  tenant_id        String
  event_type       PostingRuleEventType
  source_module    String
  source_type      String
  source_id        String
  idempotency_key  String
  status           PostingEventStatus @default(pending)
  voucher_id       String?
  attempt_count    Int               @default(0)
  last_error       String?
  last_attempt_at  DateTime?
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt

  tenant           Tenant            @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  voucher          Voucher?          @relation(fields: [voucher_id], references: [id], onDelete: SetNull)

  @@unique([tenant_id, idempotency_key])
  @@index([tenant_id, status, updated_at])
  @@index([tenant_id, source_module, source_type, source_id])
  @@map("posting_events")
}

model VoucherDetail {
  id            String   @id @default(uuid())
  voucher_id    String
  account_id    String
  debit_amount  Decimal  @default(0) @db.Decimal(12, 2)
  credit_amount Decimal  @default(0) @db.Decimal(12, 2)
  comment       String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  voucher       Voucher  @relation(fields: [voucher_id], references: [id], onDelete: Cascade)
  account       Account  @relation(fields: [account_id], references: [id])
  cost_center_id String?
  costCenter     CostCenter? @relation("VoucherDetailCostCenter", fields: [cost_center_id], references: [id])

  @@index([voucher_id])
  @@index([account_id])
  @@index([cost_center_id])
  @@map("voucher_details")
}

model PaymentRecord {
  id             String   @id @default(uuid())
  sale_id        String
  payment_method String
  amount         Decimal  @db.Decimal(12, 2)
  account_id     String?  // Links payment to account (for accounting integration)
  created_at     DateTime @default(now())

  // Relations
  sale           Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  account        Account? @relation(fields: [account_id], references: [id], onDelete: SetNull)

  @@index([account_id])
}

model SaleItem {
  id            String   @id @default(uuid())
  sale_id       String
  product_id    String
  quantity      Int
  price_at_sale Decimal  @db.Decimal(12, 2)
  
  // Relations
  sale          Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)
  product       Product  @relation(fields: [product_id], references: [id])
  returns       SalesReturnItem[]

  @@index([sale_id])
}

model SalesReturn {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  sale_id        String
  return_number  String
  total_refund   Decimal  @db.Decimal(12, 2)
  reason         String?
  status         String   @default("COMPLETED")
  created_by     String?
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  sale           Sale     @relation(fields: [sale_id], references: [id])
  items          SalesReturnItem[]

  @@unique([tenant_id, return_number])
}

model SalesReturnItem {
  id             String   @id @default(uuid())
  return_id      String
  sale_item_id   String
  product_id     String
  quantity       Int
  refund_amount  Decimal  @db.Decimal(12, 2)
  
  // Relations
  return         SalesReturn @relation(fields: [return_id], references: [id], onDelete: Cascade)
  sale_item      SaleItem    @relation(fields: [sale_item_id], references: [id])
  product        Product     @relation(fields: [product_id], references: [id])
}

model SalesOrder {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String
  customer_id    String?
  order_number   String
  total_amount   Decimal  @db.Decimal(12, 2)
  amount_paid    Decimal    @default(0) @db.Decimal(12, 2)
  status         String   @default("DRAFT") // DRAFT, CONFIRMED, PROCESSING, DELIVERED, CANCELLED
  payment_status String   @default("UNPAID") // UNPAID, PARTIAL, PAID
  delivery_date  DateTime?
  created_by     String?
  created_at     DateTime @default(now())
  
  // Relations
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store          Store    @relation(fields: [store_id], references: [id])
  customer       Customer? @relation(fields: [customer_id], references: [id])
  items          SalesOrderItem[]
  deposits       OrderDeposit[]

  @@unique([tenant_id, order_number])
  @@index([tenant_id, status])
  @@index([tenant_id, created_at])
}

model SalesOrderItem {
  id             String   @id @default(uuid())
  order_id       String
  product_id     String
  quantity       Int
  price_at_order Decimal  @db.Decimal(12, 2)
  
  // Relations
  order          SalesOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product        Product    @relation(fields: [product_id], references: [id])
}

model OrderDeposit {
  id             String   @id @default(uuid())
  order_id       String
  amount         Decimal  @db.Decimal(12, 2)
  payment_method String
  created_at     DateTime @default(now())
  
  // Relations
  order          SalesOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)
}

model Quotation {
  id                String   @id @default(uuid())
  tenant_id         String
  store_id          String
  customer_id       String?
  quote_number      String
  total_amount      Decimal  @db.Decimal(12, 2)
  status            String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED, CONVERTED, REVISED
  valid_until       DateTime?
  version           Int      @default(1)
  original_quote_id String?
  notes             String?
  created_at        DateTime @default(now())
  
  // Relations
  tenant            Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store             Store    @relation(fields: [store_id], references: [id])
  customer          Customer? @relation(fields: [customer_id], references: [id])
  items             QuotationItem[]

  @@unique([tenant_id, quote_number, version])
}

model QuotationItem {
  id             String   @id @default(uuid())
  quotation_id   String
  product_id     String
  quantity       Int
  unit_price     Decimal  @db.Decimal(12, 2)
  
  // Relations
  quotation      Quotation @relation(fields: [quotation_id], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [product_id], references: [id])
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  code          SubscriptionPlanCode @unique
  name          String
  description   String?
  monthly_price Decimal  @db.Decimal(12, 2)
  yearly_price  Decimal? @db.Decimal(12, 2)
  features_json Json     @default("{}")
  is_active     Boolean  @default(true)
  subscriptions TenantSubscription[]
}

model CashierSession {
  id            String   @id @default(uuid())
  tenant_id     String
  store_id      String
  counter_id    String?
  user_id       String   // The cashier/user who opened the session
  opened_at     DateTime @default(now())
  closed_at     DateTime?
  opening_cash  Decimal  @default(0) @db.Decimal(12, 2)
  closing_cash  Decimal  @default(0) @db.Decimal(12, 2)
  status        String   @default("OPEN") // OPEN, CLOSED

  // Relations
  tenant        Tenant      @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store         Store       @relation(fields: [store_id], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  counter       PosCounter? @relation(fields: [counter_id], references: [id])
  cashTransactions CashTransaction[]

  @@index([tenant_id, status])
  @@index([tenant_id, counter_id])
}

model CashTransaction {
  id            String   @id @default(uuid())
  tenant_id     String
  session_id    String
  amount        Decimal  @db.Decimal(12, 2) // Positive for cash in, negative for cash out
  type          String   // e.g., 'DROP', 'LOAN', 'PAYOUT', 'OTHER'
  description   String?
  created_at    DateTime @default(now())
   
  // Relations
  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  session       CashierSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  tenant_id          String             @unique
  plan_id            String
  status             SubscriptionStatus @default(TRIALING)
  current_period_start DateTime         @default(now())
  current_period_end DateTime
  cancel_at_period_end Boolean          @default(false)
  provider_name      String?
  provider_customer_ref String?
  provider_subscription_ref String?
  
  // Relations
  tenant             Tenant             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  plan               SubscriptionPlan   @relation(fields: [plan_id], references: [id])

  @@index([plan_id, status])
}

model BillingEvent {
  id                 String   @id @default(uuid())
  tenant_id          String
  provider_name      String
  external_event_id  String
  event_type         String
  status             String
  reference_id       String?
  amount             Decimal? @db.Decimal(12, 2)
  currency           String?
  payload            Json
  created_at         DateTime @default(now())

  tenant             Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([provider_name, external_event_id])
  @@index([tenant_id, created_at])
  @@index([tenant_id, provider_name])
}

// ── SMS Credits (prepaid balance the shop spends when sending SMS) ────────────

// Purchasable top-up packages (number of SMS credits for a fixed price).
model SmsPackage {
  id         String   @id @default(uuid())
  name       String
  credits    Int                              // SMS credits granted on purchase
  price      Decimal  @db.Decimal(12, 2)      // price for the package
  currency   String   @default("BDT")
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  @@index([is_active, sort_order])
}

// Ledger of every change to a tenant's SMS credit balance.
model SmsTransaction {
  id            String   @id @default(uuid())
  tenant_id     String
  type          String   // PURCHASE | USAGE | ADJUSTMENT | REFUND
  credits       Int      // positive = credited, negative = consumed
  balance_after Int      // resulting balance after this entry
  description   String?
  recipient     String?  // destination phone number for USAGE entries
  reference     String?  // billing/payment reference for PURCHASE entries
  created_at    DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
}

// ── Multi-Store Access & Permission Models ───────────────────────────────────

model UserStoreAccess {
  id           String   @id @default(uuid())
  user_id      String
  store_id     String
  tenant_id    String
  // STORE_ONLY = access to exactly this one context
  // MULTI_STORE_CAPABLE = can switch between assigned stores
  access_level String   @default("STORE_ONLY")
  created_at   DateTime @default(now())

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store        Store    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([user_id, store_id])
  @@index([tenant_id, store_id])
  @@index([user_id, tenant_id])
}

model UserStorePermission {
  id           String          @id @default(uuid())
  user_id      String
  store_id     String
  tenant_id    String
  permission   StorePermission
  granted_by   String
  granted_at   DateTime        @default(now())

  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  store        Store           @relation(fields: [store_id], references: [id], onDelete: Cascade)
  tenant       Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([user_id, store_id, permission])
  @@index([user_id, store_id])
  @@index([tenant_id, store_id, permission])
}

// Store-specific product price overrides.
// store_id = NULL means base price (default for all stores).
model ProductPrice {
  id             String    @id @default(uuid())
  tenant_id      String
  product_id     String
  store_id       String?
  price          Decimal   @db.Decimal(12, 2)
  cost           Decimal?  @db.Decimal(12, 2)
  effective_from DateTime  @default(now())
  effective_to   DateTime?
  created_at     DateTime  @default(now())

  tenant         Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [product_id], references: [id], onDelete: Cascade)
  store          Store?    @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, product_id, store_id])
  @@index([product_id, store_id, effective_from])
}

model FundTransfer {
  id                    String    @id @default(uuid())
  tenant_id             String
  source_store_id       String
  destination_store_id  String
  amount                Decimal   @db.Decimal(12, 2)
  method                String    @default("CASH")  // CASH, CHECK, BANK_TRANSFER
  description           String?
  // INITIATED, IN_TRANSIT, RECEIVED, CANCELLED
  status                String    @default("INITIATED")
  initiated_by          String
  received_by           String?
  // Voucher linkage for accounting integration
  source_voucher_id     String?
  destination_voucher_id String?
  created_at            DateTime  @default(now())
  received_at           DateTime?

  tenant                Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  sourceStore           Store     @relation("FundTransferSourceStore", fields: [source_store_id], references: [id])
  destinationStore      Store     @relation("FundTransferDestinationStore", fields: [destination_store_id], references: [id])
  initiatedByUser       User      @relation("FundTransferInitiator", fields: [initiated_by], references: [id])
  receivedByUser        User?     @relation("FundTransferReceiver", fields: [received_by], references: [id])
  sourceVoucher         Voucher?  @relation("FundTransferSourceVoucher", fields: [source_voucher_id], references: [id])
  destinationVoucher    Voucher?  @relation("FundTransferDestinationVoucher", fields: [destination_voucher_id], references: [id])

  @@index([tenant_id, status, created_at])
  @@index([tenant_id, source_store_id])
  @@index([tenant_id, destination_store_id])
}

// Warranty claim statuses: SUBMITTED, APPROVED, REJECTED, REPAIRED, REPLACED, COMPLETED
model WarrantyClaim {
  id                       String    @id @default(uuid())
  tenant_id                String
  store_id                 String
  claim_number             String
  serial_number            String
  product_id               String
  sale_id                  String?
  customer_id              String?
  status                   String    @default("SUBMITTED")
  reason                   String
  description              String?
  resolution_notes         String?
  replacement_serial_number String?
  resolved_at              DateTime?
  created_at               DateTime  @default(now())
  updated_at               DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store            Store     @relation(fields: [store_id], references: [id])
  sale             Sale?     @relation(fields: [sale_id], references: [id])
  customer         Customer? @relation(fields: [customer_id], references: [id])
  product          Product   @relation(fields: [product_id], references: [id])

  @@unique([tenant_id, claim_number])
  @@index([tenant_id, status, created_at])
  @@index([tenant_id, serial_number])
  @@index([tenant_id, product_id])
  @@index([tenant_id, customer_id])
}

model Feedback {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  type       String   // 'bug' | 'feature' | 'general'
  message    String
  page       String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("feedbacks")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  key_hash   String    @unique  // SHA-256 hash of the actual key
  key_prefix String             // first 8 chars for display (e.g. "rsk_live")
  last_used  DateTime?
  created_at DateTime  @default(now())
  revoked_at DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("api_keys")
}

model StorefrontOrder {
  id            String   @id @default(cuid())
  tenantId      String
  customerName  String
  customerEmail String
  customerPhone String?
  items         StorefrontOrderItem[]
  totalAmount      Decimal  @db.Decimal(12, 2)
  status           String   @default("PENDING")
  notes            String?
  customerUserId   String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerUser User?  @relation(fields: [customerUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerUserId])
  @@map("storefront_orders")
}

model StorefrontOrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  quantity     Int
  priceAtOrder Decimal @db.Decimal(12, 2)

  order   StorefrontOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@map("storefront_order_items")
}

model DeliveryOrder {
  id              String    @id @default(cuid())
  tenantId        String
  saleId          String?
  customerName    String
  customerPhone   String?
  deliveryAddress String
  driverName      String?
  driverPhone     String?
  status          String    @default("PENDING")
  notes           String?
  scheduledAt     DateTime?
  deliveredAt     DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   Sale?  @relation(fields: [saleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("delivery_orders")
}

// Bill of Materials: defines what components go into making 1 unit of a product
model BomRecipe {
  id           String   @id @default(cuid())
  tenantId     String
  productId    String   @unique  // the manufactured/output product
  outputQty    Int      @default(1)
  notes        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product      @relation(fields: [productId], references: [id])
  components BomComponent[]
  productionJobs ProductionJob[]

  @@index([tenantId])
  @@map("bom_recipes")
}

model BomComponent {
  id        String   @id @default(cuid())
  recipeId  String
  productId String   // the raw material / component product
  quantity  Decimal  @db.Decimal(12, 4)

  recipe    BomRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product   Product   @relation("BomComponent", fields: [productId], references: [id])

  @@map("bom_components")
}

// A production run: manufacture N units of a product
model ProductionJob {
  id           String   @id @default(cuid())
  tenantId     String
  recipeId     String
  productId    String   // output product (denormalised for easy querying)
  quantity     Int
  status       String   @default("DRAFT")  // DRAFT | IN_PROGRESS | COMPLETED | CANCELLED
  notes        String?
  startedAt    DateTime?
  completedAt  DateTime?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tenant  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipe  BomRecipe @relation(fields: [recipeId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("production_jobs")
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  saleId      String?
  type        String   // EARN | REDEEM | ADJUST
  points      Int      // positive = earn, negative = redeem/adjust
  description String?
  created_at  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId])
  @@index([customerId])
  @@map("loyalty_transactions")
}

model DiscountCode {
  id           String    @id @default(cuid())
  tenantId     String
  code         String
  name         String
  type         String    // PERCENTAGE | FIXED
  value        Decimal   @db.Decimal(10, 2)  // percent (0-100) or fixed BDT amount
  min_purchase Decimal?  @db.Decimal(12, 2)  // minimum cart total to apply
  max_discount Decimal?  @db.Decimal(12, 2)  // cap for PERCENTAGE type
  usage_limit  Int?                           // null = unlimited
  used_count   Int       @default(0)
  valid_from   DateTime?
  valid_until  DateTime?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, is_active])
  @@map("discount_codes")
}

model Notification {
  id         String    @id @default(uuid())
  tenant_id  String
  user_id    String
  type       String    // LOW_STOCK | SUBSCRIPTION_EXPIRY | INFO
  title      String
  body       String
  link       String?
  read_at    DateTime?
  created_at DateTime  @default(now())

  tenant     Tenant    @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, user_id, created_at])
  @@index([user_id, read_at])
}

model Department {
  id         String     @id @default(uuid())
  tenant_id  String
  name       String
  created_at DateTime   @default(now())
  deleted_at DateTime?

  tenant     Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  employees  Employee[]

  @@unique([tenant_id, name])
  @@index([tenant_id, deleted_at])
}

model Designation {
  id         String     @id @default(uuid())
  tenant_id  String
  name       String
  created_at DateTime   @default(now())
  deleted_at DateTime?

  tenant     Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  employees  Employee[]

  @@unique([tenant_id, name])
  @@index([tenant_id, deleted_at])
}

model Employee {
  id              String         @id @default(uuid())
  tenant_id       String
  employee_code   String
  name            String
  phone           String
  email           String?
  nid             String?
  date_of_joining DateTime?
  department_id   String?
  designation_id  String?
  user_id         String?        @unique
  basic_salary    Decimal?       @db.Decimal(12, 2)
  status          EmployeeStatus @default(ACTIVE)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  deleted_at      DateTime?

  tenant      Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  department  Department?  @relation(fields: [department_id], references: [id])
  designation Designation? @relation(fields: [designation_id], references: [id])
  user        User?        @relation(fields: [user_id], references: [id])
  attendanceRecords AttendanceRecord[]
  leaveBalances     LeaveBalance[]
  leaveRequests     LeaveRequest[]
  salaryPayments    SalaryPayment[]

  @@unique([tenant_id, employee_code])
  @@unique([tenant_id, phone])
  @@index([tenant_id, status, deleted_at])
  @@index([tenant_id, department_id])
  @@index([tenant_id, designation_id])
}

model LeaveType {
  id            String    @id @default(uuid())
  tenant_id     String
  name          String
  days_per_year Float     @default(0)
  created_at    DateTime  @default(now())
  deleted_at    DateTime?

  tenant    Tenant         @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  balances  LeaveBalance[]
  requests  LeaveRequest[]

  @@unique([tenant_id, name])
  @@index([tenant_id, deleted_at])
}

model LeaveBalance {
  id            String   @id @default(uuid())
  tenant_id     String
  employee_id   String
  leave_type_id String
  year          Int
  total_days    Float    @default(0)
  used_days     Float    @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  leave_type LeaveType  @relation(fields: [leave_type_id], references: [id])

  @@unique([tenant_id, employee_id, leave_type_id, year])
  @@index([tenant_id, employee_id])
}

model AttendanceRecord {
  id          String           @id @default(uuid())
  tenant_id   String
  employee_id String
  date        DateTime         @db.Date
  clock_in    DateTime?
  clock_out   DateTime?
  status      AttendanceStatus @default(PRESENT)
  notes       String?
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt

  tenant   Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, employee_id, date])
  @@index([tenant_id, date])
  @@index([tenant_id, employee_id, date])
}

model LeaveRequest {
  id            String             @id @default(uuid())
  tenant_id     String
  employee_id   String
  leave_type_id String
  start_date    DateTime           @db.Date
  end_date      DateTime           @db.Date
  days          Float
  reason        String?
  status        LeaveRequestStatus @default(PENDING)
  approved_by   String?
  approved_at   DateTime?
  approver_note String?
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  deleted_at    DateTime?

  tenant     Tenant     @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  leave_type LeaveType  @relation(fields: [leave_type_id], references: [id])
  approver   User?      @relation("LeaveApprover", fields: [approved_by], references: [id])

  @@index([tenant_id, employee_id, status])
  @@index([tenant_id, status, start_date])
}

model FiscalPeriod {
  id                String   @id @default(uuid())
  tenant_id         String
  year              Int
  month             Int
  period_label      String
  start_date        DateTime
  end_date          DateTime
  is_locked         Boolean  @default(false)
  locked_at         DateTime?
  locked_by_user_id String?

  tenant            Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, year, month])
  @@index([tenant_id])
  @@map("fiscal_periods")
}

model AccountBudget {
  id          String   @id @default(uuid())
  tenant_id   String
  account_id  String
  fiscal_year Int
  month       Int?
  amount      Decimal  @db.Decimal(12, 2)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  account     Account  @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@unique([tenant_id, account_id, fiscal_year, month])
  @@index([tenant_id, fiscal_year])
  @@map("account_budgets")
}

model CostCenter {
  id         String   @id @default(uuid())
  tenant_id  String
  code       String
  name       String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  voucherDetails VoucherDetail[] @relation("VoucherDetailCostCenter")

  @@unique([tenant_id, code])
  @@index([tenant_id])
  @@map("cost_centers")
}

model FixedAsset {
  id                       String             @id @default(uuid())
  tenant_id                String
  asset_code               String
  name                     String
  purchase_date            DateTime
  cost                     Decimal            @db.Decimal(12, 2)
  residual_value           Decimal            @db.Decimal(12, 2) @default(0)
  useful_life_months       Int
  depreciation_method      DepreciationMethod @default(STRAIGHT_LINE)
  accumulated_depreciation Decimal            @db.Decimal(12, 2) @default(0)
  disposal_date            DateTime?
  asset_account_id         String?
  depreciation_account_id  String?
  is_active                Boolean            @default(true)
  created_at               DateTime           @default(now())
  updated_at               DateTime           @updatedAt

  tenant              Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  depreciationEntries AssetDepreciationEntry[]

  @@unique([tenant_id, asset_code])
  @@index([tenant_id])
  @@map("fixed_assets")
}

model AssetDepreciationEntry {
  id                   String   @id @default(uuid())
  asset_id             String
  period_year          Int
  period_month         Int
  depreciation_amount  Decimal  @db.Decimal(12, 2)
  voucher_id           String?
  created_at           DateTime @default(now())

  asset   FixedAsset @relation(fields: [asset_id], references: [id], onDelete: Cascade)

  @@unique([asset_id, period_year, period_month])
  @@index([asset_id])
  @@map("asset_depreciation_entries")
}

model RecurringJournal {
  id               String   @id @default(uuid())
  tenant_id        String
  name             String
  description      String?
  frequency        String
  next_due_date    DateTime
  last_run_date    DateTime?
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  lines            RecurringJournalLine[]

  @@index([tenant_id])
  @@index([tenant_id, next_due_date, is_active])
  @@map("recurring_journals")
}

model RecurringJournalLine {
  id                    String  @id @default(uuid())
  recurring_journal_id  String
  account_id            String
  debit_amount          Decimal @db.Decimal(12, 2) @default(0)
  credit_amount         Decimal @db.Decimal(12, 2) @default(0)
  comment               String?

  recurringJournal RecurringJournal @relation(fields: [recurring_journal_id], references: [id], onDelete: Cascade)
  account          Account          @relation(fields: [account_id], references: [id])

  @@index([recurring_journal_id])
  @@map("recurring_journal_lines")
}

model BankReconciliation {
  id                        String   @id @default(uuid())
  tenant_id                 String
  account_id                String
  statement_date            DateTime
  statement_closing_balance Decimal  @db.Decimal(12, 2)
  status                    String   @default("OPEN")
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  entries BankStatementEntry[]

  @@index([tenant_id, account_id])
  @@map("bank_reconciliations")
}

model BankStatementEntry {
  id                        String   @id @default(uuid())
  reconciliation_id         String
  entry_date                DateTime
  description               String?
  amount                    Decimal  @db.Decimal(12, 2)
  entry_type                String
  is_matched                Boolean  @default(false)
  matched_voucher_detail_id String?
  created_at                DateTime @default(now())

  reconciliation BankReconciliation @relation(fields: [reconciliation_id], references: [id], onDelete: Cascade)

  @@index([reconciliation_id])
  @@map("bank_statement_entries")
}

model PlatformSetting {
  id         Int      @id @default(autoincrement())
  group      String
  key        String
  value      String?
  is_secret  Boolean  @default(false)
  updated_at DateTime @updatedAt
  updated_by String?

  @@unique([group, key])
  @@map("platform_settings")
}

model ExpenseCategory {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  entries     ExpenseEntry[]
  @@unique([tenant_id, name])
  @@index([tenant_id])
}

model ExpenseEntry {
  id             String   @id @default(uuid())
  tenant_id      String
  store_id       String?
  category_id    String
  amount         Decimal  @db.Decimal(12, 2)
  expense_date   DateTime @db.Date
  description    String?
  payment_method String   @default("CASH")
  created_by     String?
  created_at     DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  category       ExpenseCategory @relation(fields: [category_id], references: [id])
  store          Store?   @relation(fields: [store_id], references: [id])
  @@index([tenant_id, expense_date])
  @@index([tenant_id, category_id])
}

// ── Loans ───────────────────────────────────────────────────────────────────

model Loan {
  id            String    @id @default(uuid())
  tenant_id     String
  store_id      String?
  // Who the loan is with: the lender (for PAYABLE) or the borrower (for RECEIVABLE).
  counterparty  String
  // PAYABLE  = money the business borrowed (a liability)
  // RECEIVABLE = money the business lent out (an asset)
  direction     String    @default("PAYABLE")
  principal     Decimal   @db.Decimal(14, 2)
  // Optional annual interest rate (%), informational only.
  interest_rate Decimal?  @db.Decimal(5, 2)
  start_date    DateTime  @db.Date
  due_date      DateTime? @db.Date
  // ACTIVE | CLOSED
  status        String    @default("ACTIVE")
  reference     String?
  notes         String?
  created_by    String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  tenant        Tenant        @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  store         Store?        @relation(fields: [store_id], references: [id])
  payments      LoanPayment[]
  @@index([tenant_id, status])
  @@index([tenant_id, direction])
}

model LoanPayment {
  id             String   @id @default(uuid())
  tenant_id      String
  loan_id        String
  amount         Decimal  @db.Decimal(14, 2)
  payment_date   DateTime @db.Date
  payment_method String   @default("CASH")
  notes          String?
  created_by     String?
  created_at     DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  loan           Loan     @relation(fields: [loan_id], references: [id], onDelete: Cascade)
  @@index([tenant_id, loan_id])
  @@index([tenant_id, payment_date])
}

// ── Salary Payments ─────────────────────────────────────────────────────────

model SalaryPayment {
  id             String   @id @default(uuid())
  tenant_id      String
  employee_id    String
  amount         Decimal  @db.Decimal(12, 2)
  pay_period     String   // 'YYYY-MM' — the month the salary is for
  payment_date   DateTime @db.Date
  payment_method String   @default("CASH")
  notes          String?
  created_by     String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employee_id], references: [id])

  @@unique([tenant_id, employee_id, pay_period])
  @@index([tenant_id, payment_date])
  @@index([tenant_id, employee_id])
}

// ── AI Usage Logging ──────────────────────────────────────────────────────────

model AiUsageLog {
  id                    String   @id @default(cuid())
  tenant_id             String
  feature               String   // 'report_narration' | 'message_drafter' | etc.
  model                 String
  input_tokens          Int
  output_tokens         Int
  cache_read_tokens     Int      @default(0)
  cache_creation_tokens Int      @default(0)
  cost_usd              Float
  credits_used          Float    // tokens / 1000
  created_at            DateTime @default(now())

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: Cascade)

  @@index([tenant_id, created_at])
  @@index([tenant_id, feature, created_at])
}

// ── Support Chat ──────────────────────────────────────────────────────────────

model SupportThread {
  id        String   @id @default(cuid())
  tenantId  String
  subject   String
  status    String   @default("open")  // open | resolved
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([tenantId, status])
  @@map("support_threads")
}

model SupportMessage {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  senderRole String   // "owner" | "admin"
  body       String
  createdAt  DateTime @default(now())

  thread SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("SupportMessageSender", fields: [senderId], references: [id])

  @@index([threadId, createdAt])
  @@map("support_messages")
}
