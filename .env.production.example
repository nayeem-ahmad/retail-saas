NODE_ENV=production

# Public application URLs
FRONTEND_URL=https://app.nayeemahmad.com
BACKEND_PUBLIC_URL=https://api.nayeemahmad.com
NEXT_PUBLIC_API_BASE=https://api.nayeemahmad.com
NEXT_PUBLIC_API_URL=https://api.nayeemahmad.com

# VPS Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=erp71
DATABASE_URL=postgresql://postgres:change-this-db-password@db:5432/erp71
DIRECT_URL=postgresql://postgres:change-this-db-password@db:5432/erp71

# Supabase auth/storage values still used by the application if enabled
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_READ_URL=your-supabase-read-replica-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Auth and admin
JWT_SECRET=generate-a-long-random-secret
PLATFORM_ADMIN_EMAILS=nayeem.ahmad@gmail.com
FIELD_ENCRYPTION_KEY=generate-64-hex-chars
REQUIRE_EMAIL_VERIFICATION=true

# Billing and payments
BILLING_PROVIDER=SSL_WIRELESS
SSL_WIRELESS_STORE_ID=your-ssl-wireless-store-id
SSL_WIRELESS_STORE_PASSWORD=your-ssl-wireless-store-password
SSL_WIRELESS_API_URL=https://sandbox.sslcommerz.com/gwprocess/v4/api.php
SSL_WIRELESS_VALIDATION_URL=https://sandbox.sslcommerz.com/validator/api/validationserverAPI.php
SSL_WIRELESS_SUCCESS_REDIRECT=https://app.nayeemahmad.com/dashboard/billing
SSL_WIRELESS_FAIL_REDIRECT=https://app.nayeemahmad.com/dashboard/billing
SSL_WIRELESS_CANCEL_REDIRECT=https://app.nayeemahmad.com/dashboard/billing
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_API_URL=https://api.bkash.com/sandbox
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_API_KEY=your-nagad-api-key
NAGAD_API_URL=https://api.nagad.com.bd/sandbox

# Email and support
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
EMAIL_FROM=noreply@nayeemahmad.com
SUPPORT_EMAIL=support@nayeemahmad.com
FEEDBACK_EMAIL=feedback@nayeemahmad.com

# Infrastructure and observability
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# System health monitoring thresholds (platform-admin /admin/system-health)
HEALTH_DEP_TIMEOUT_MS=2000
HEALTH_DB_LATENCY_DEGRADED_MS=1000
HEALTH_DB_POOL_DEGRADED_PCT=80
# Prometheus metrics scrape endpoint (GET /api/v1/metrics); leave unset to disable
METRICS_TOKEN=
# Threshold alerting — notify platform admins when the system is degraded/down
HEALTH_ALERT_EMAILS=
HEALTH_ALERT_SMS=
HEALTH_ALERT_COOLDOWN_MIN=30
HEALTH_PAYMENT_FAILURE_THRESHOLD=3
HEALTH_PAYMENT_FAILURE_WINDOW_MIN=60
SMS_CREDIT_LOW_THRESHOLD=100
SMS_CREDIT_LOW_TENANTS_ALERT=5
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=your-frontend-sentry-dsn
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=erp71-frontend